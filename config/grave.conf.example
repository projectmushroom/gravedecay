# grave configuration — sourced by /usr/local/bin/grave (bash syntax).
# raise.sh installs this to /etc/gravedecay/grave.conf with @TOKENS@ filled in.

# Root of the dev platform
GRAVE_ROOT="@GRAVE_ROOT@"

# systemd services that are part of "developer mode" (stopped by gaming mode)
DEV_SERVICES=(t3code)

# Docker compose stacks under $GRAVE_ROOT/docker started in developer mode.
# Order matters: started in this order, stopped in reverse.
DEV_STACKS=(core browsers)

# Container engine. On immutable hosts (e.g. stock SteamOS) raise.sh installs
# rootless Docker: it runs as your user with NO sudo, on a per-user socket, and
# lives under $HOME so it survives OS updates. When DOCKER_ROOTLESS=1 grave
# talks to the daemon as the user (docker + `systemctl --user`); when 0 it uses
# `sudo docker` and the system docker unit. Both keep containers on 127.0.0.1.
DOCKER_ROOTLESS=@DOCKER_ROOTLESS@
DOCKER_HOST="@DOCKER_HOST@"

# Extra PATH prepended by grave so it finds the durable toolchain (Homebrew
# bins, rootless docker under $HOME). Empty on package-manager hosts. Must end
# with a trailing ':' when non-empty. Set by raise.sh.
TOOL_PATH="@TOOL_PATH@"

# systemd services that must NEVER be touched by grave gaming/stop.
# Host profiles may append machine-specific units (GPU pinning etc.).
ALWAYS_ON=(tailscaled sshd NetworkManager gravedecay gravedecay-term)

# Game-mode auto-throttle (Steam Machine): gravedecay-gamewatch polls for a
# running game and flips grave gaming/developer. Toggle with `grave gamewatch
# on|off` (a flag file, not here). These just tune detection.
GAME_POLL_SECONDS=8
GAME_PROC="reaper"        # Steam's per-game wrapper process (matched by name)

# tmux socket name used for agent sessions
TMUX_SOCKET="agents"
TMUX_CONF="$GRAVE_ROOT/config/tmux.conf"

# Agent configs (in $HOME) included in backups
AGENT_CONFIG_DIRS=(.claude .codex .gemini)

# npm -g tools refreshed by `grave update`
NPM_GLOBAL_TOOLS=(t3)

# Backups
BACKUP_DIR="$GRAVE_ROOT/backups"
BACKUP_KEEP=7

# Push notifications (`grave notify`, docs/NOTIFICATIONS.md). The channel
# itself lives in $GRAVE_ROOT/config/secrets/notify.env (NTFY_URL + optional
# NTFY_TOKEN, chmod 600) — this only picks which event classes may page the
# human. Remove a word to mute that class:
#   session-exit / bell  agent tmux sessions ending / ringing the bell
#   unit-failure         a platform systemd unit entered failed state
#   doctor               a doctor run found failing checks
NOTIFY_EVENTS="session-exit bell unit-failure doctor"

# `grave upgrade` — where the gravedecay checkout lives, and which channel:
# release = latest v* tag (recommended), edge = main branch (for developers)
REPO_DIR="$GRAVE_ROOT/repos/gravedecay"
UPGRADE_CHANNEL=release

# Ports (documented in docs/PORTS.md)
T3_PORT=4711
DASH_PORT=4712
TERM_PORT=4713

# Opt-in isolated workspaces. `grave users add` prepares records; issue #27's
# migration command enables this only after validating and backing up owner state.
MULTI_USER=0
GATEWAY_PORT=4710

# Port range `grave preview` may expose to the tailnet. A preview serves a
# loopback dev server at https://<box>.ts.net:<port> (root path, HMR-safe).
# Confined to this range so a preview can't shadow a platform service.
# PREVIEW_RESERVED lists platform ports inside the range that must never be
# exposed (Playwright is on 3050) — grave refuses to preview them.
PREVIEW_RANGE=3000-3999
PREVIEW_RESERVED="3050"

# Doctor toggles — set to 1 when the host profile establishes the invariant
CHECK_SLEEP_MASKED=0     # sleep/suspend targets masked (always-on box)
CHECK_LID_IGNORED=0      # laptop lid close ignored at logind level
CHECK_DOCKER_SUBVOL=0    # /var/lib/docker on its own btrfs subvolume
CHECK_SNAPPER=0          # snapper timeline for $GRAVE_ROOT
SNAPPER_CONFIG=srv
CHECK_IMMUTABLE_ROOT=0   # immutable rootfs (SteamOS): toolchain must live in $HOME
CHECK_FIREWALL=1         # require a host firewall (steam-machine sets 0 for LAN gaming)
