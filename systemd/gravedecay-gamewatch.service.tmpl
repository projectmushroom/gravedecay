[Unit]
Description=gravedecay optional game-mode auto-throttle (freeze agents while gaming)
# Watches for a running game and flips grave gaming/developer. The hot-reloaded
# flag at $GRAVE_ROOT/config/gamewatch.on is synchronized from the persistent
# gamewatch.preference by raise.sh / grave gamewatch — see docs/STEAMOS.md.
After=multi-user.target
Wants=network-online.target
# Page the human if this unit lands in failed state (silent no-op unless
# notifications are configured -- see docs/NOTIFICATIONS.md).
OnFailure=gravedecay-notify@%n.service

[Service]
Type=simple
User=@USER@
Group=@USER@
ExecStart=@GRAVE_ROOT@/scripts/gravedecay-gamewatch
Restart=always
RestartSec=5
Environment=HOME=@HOME@
# Reach the durable toolchain (grave, docker, busctl) — @TOOLPATH@ is the
# Homebrew/rootless bins; empty on package-manager hosts. XDG_RUNTIME_DIR is set
# by the script itself so busctl --user reaches the session bus.
Environment=PATH=@TOOLPATH@@HOME@/.local/bin:/usr/local/bin:/usr/bin:/bin

# NO PrivateTmp: grave gaming freezes agents via the tmux socket in /tmp

[Install]
WantedBy=multi-user.target
