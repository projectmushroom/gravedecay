#!/usr/bin/env bash
# webterm — session picker for the gravedecay web terminal (ttyd runs this).
# The URL arg picks the session: /term/?arg=shell|claude|codex|<name>.
# Every session lives in the shared `tmux -L agents` socket, so the browser,
# SSH, and `grave agents attach` all reach the SAME persistent session, and
# closing the tab never kills the process.
set -euo pipefail
GRAVE_ROOT="${GRAVE_ROOT:-/srv/dev}"

choice="${1:-shell}"
name="${choice//[^a-zA-Z0-9_-]/}"
[[ -n "$name" ]] || name=shell

case "$name" in
  claude) cmd=(claude) ;;
  codex)  cmd=(codex) ;;
  *)      cmd=() ;;         # plain login shell
esac

# -A: attach if the session exists, create it if not
exec tmux -L agents -f "$GRAVE_ROOT/config/tmux.conf" \
  new-session -A -s "$name" "${cmd[@]}"
