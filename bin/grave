#!/usr/bin/env bash
# grave — unified control tool for a gravedecay appliance.
# Docs: $GRAVE_ROOT/docs (or the gravedecay repo)   Config: /etc/gravedecay/grave.conf
set -euo pipefail

CONF="${GRAVE_CONF:-/etc/gravedecay/grave.conf}"
[[ -r "$CONF" ]] || { echo "grave: config not found at $CONF (run raise.sh first)"; exit 1; }
# shellcheck disable=SC1090
source "$CONF"

# On a managed-toolchain host (Homebrew + rootless docker under $HOME) the tools
# grave shells out to — docker, tailscale, tmux — aren't on a bare login PATH.
# TOOL_PATH (set by raise.sh; empty on package-manager hosts) makes grave
# self-sufficient regardless of how it was invoked.
[[ -n "${TOOL_PATH:-}" ]] && export PATH="$TOOL_PATH$PATH"

# Tailnet port range for `grave preview` (dev-server tunnels), and any platform
# ports that fall inside it and must never be exposed (Playwright is on 3050).
# Defaults here so installs whose grave.conf predates the feature still work;
# documented in docs/PORTS.md and grave.conf.example.
: "${PREVIEW_RANGE:=3000-3999}"
: "${PREVIEW_RESERVED:=3050}"

LOG_FILE="$GRAVE_ROOT/logs/grave.log"
RED=$'\e[31m'; GRN=$'\e[32m'; YLW=$'\e[33m'; BLD=$'\e[1m'; RST=$'\e[0m'

log() { { printf '%s %s\n' "$(date '+%F %T')" "$*" >> "$LOG_FILE"; } 2>/dev/null || true; }
say() { printf '%s\n' "$*"; }
ok()  { printf '  %b✓%b %s\n' "$GRN" "$RST" "$*"; }
bad() { printf '  %b✗%b %s\n' "$RED" "$RST" "$*"; }
hdr() { printf '\n%b%s%b\n' "$BLD" "$*" "$RST"; }

need_root_helper() { sudo -n true 2>/dev/null || { say "grave needs passwordless sudo for this (see docs/SECURITY.md)"; exit 1; }; }

tmuxa() { tmux -L "$TMUX_SOCKET" "$@"; }

# Container engine: rootless Docker (per-user, no sudo — durable on immutable
# hosts like SteamOS) vs system Docker (sudo). dk = the docker CLI, dkctl =
# how we manage the docker unit (per-user vs system systemd). Everything else
# in grave calls these two, so the sudo/rootless split lives in one place.
if [[ "${DOCKER_ROOTLESS:-0}" == 1 ]]; then
  export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
  [[ -n "${DOCKER_HOST:-}" ]] && export DOCKER_HOST
  _DOCKER=(docker);      _DKCTL=(systemctl --user)
else
  _DOCKER=(sudo docker); _DKCTL=(sudo systemctl)
fi
dk()    { "${_DOCKER[@]}" "$@"; }
dkctl() { "${_DKCTL[@]}"  "$@"; }

compose() { # compose <stack> <args...>
  local stack="$1"; shift
  dk compose --project-directory "$GRAVE_ROOT/docker/$stack" "$@"
}

mem_available_mib() { awk '/MemAvailable/ {print int($2/1024)}' /proc/meminfo; }

pkg_mgr() {
  if command -v pacman >/dev/null; then echo pacman
  elif command -v apt-get >/dev/null; then echo apt
  elif command -v dnf >/dev/null; then echo dnf
  else echo none; fi
}

t3_version() {
  t3 --version 2>/dev/null | sed -n 's/^t3 v//p' | head -1
}

t3_latest_version() {
  npm view t3 dist-tags.latest --silent 2>/dev/null | tail -1
}

cmd_t3() { # grave t3 [status|update] — inspect/update the stable T3 Code CLI
  local sub="${1:-status}" installed latest t3_bin npm_bin
  command -v t3 >/dev/null 2>&1 || { bad "t3 is not installed"; exit 1; }
  command -v npm >/dev/null 2>&1 || { bad "npm is not installed"; exit 1; }
  installed=$(t3_version)
  [[ -n "$installed" ]] || { bad "t3 is installed but does not run"; exit 1; }
  latest=$(t3_latest_version)
  [[ "$latest" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || {
    bad "could not resolve npm's stable t3 version"; exit 1;
  }

  case "$sub" in
    status)
      say "T3 Code: installed v$installed; stable v$latest"
      [[ "$installed" == "$latest" ]] && ok "T3 Code is up to date" || say "  update available — run: grave t3 update"
      ;;
    update)
      if [[ "$installed" == "$latest" ]]; then
        ok "T3 Code v$installed is already up to date"
        return
      fi
      say "Updating T3 Code v$installed → v$latest (stable)..."
      t3_bin=$(command -v t3)
      npm_bin=$(command -v npm)
      if [[ "$t3_bin" == "$HOME/.local/"* ]]; then
        # SteamOS: node-pty must be rebuilt against the pinned Node ABI using
        # the header wrappers created by steamos-toolchain.sh.
        local wrappers="$HOME/.local/toolchain-wrappers"
        PATH="$wrappers:$(dirname "$npm_bin"):$PATH" CC=cc CXX=c++ \
          "$npm_bin" install -g --prefix "$HOME/.local" "t3@$latest"
      else
        need_root_helper
        # Package-manager hosts install t3 system-wide. npm update follows the
        # package's stable latest tag; the exact result is validated below.
        sudo npm update -g t3
      fi
      local updated
      updated=$(t3_version)
      [[ "$updated" == "$latest" ]] || {
        bad "update validation failed: expected v$latest, found v${updated:-unknown}"
        exit 1
      }
      if systemctl is-active --quiet t3code; then
        sudo -n systemctl restart t3code
        if curl -sf --retry 10 --retry-delay 1 -o /dev/null \
            "http://127.0.0.1:$T3_PORT/"; then
          ok "t3code answering after restart"
        else
          bad "t3code did not answer after restart"
          exit 1
        fi
      else
        say "  t3code is stopped (gaming mode?) — it will use v$updated next start"
      fi
      log "t3: updated v$installed to v$updated"
      ok "T3 Code updated to v$updated"
      ;;
    *) say "usage: grave t3 [status|update]"; exit 1 ;;
  esac
}

# ---------------------------------------------------------------- status ----
cmd_status() {
  hdr "Always-on services"
  local s
  for s in "${ALWAYS_ON[@]}"; do
    if systemctl is-active --quiet "$s"; then ok "$s"; else bad "$s (inactive)"; fi
  done

  hdr "Developer services"
  for s in "${DEV_SERVICES[@]}"; do
    if systemctl is-active --quiet "$s"; then ok "$s"; else bad "$s (stopped)"; fi
  done
  if dkctl is-active --quiet docker; then
    ok "docker"
    dk ps --format '    {{.Names}}: {{.Status}}' 2>/dev/null || true
  else
    bad "docker (stopped)"
  fi

  hdr "Agent tmux sessions ($TMUX_SOCKET)"
  local sessions
  sessions=$(tmuxa list-sessions 2>/dev/null || true)
  if [[ -n "$sessions" ]]; then sed 's/^/    /' <<<"$sessions"; else say "    (none)"; fi

  hdr "Tailscale"
  if command -v tailscale >/dev/null && tailscale status --peers=false >/dev/null 2>&1; then
    tailscale status --peers=false | sed 's/^/    /'
  else
    bad "tailscale not connected"
  fi

  hdr "System"
  printf '    uptime:%s\n' "$(uptime -p | sed 's/^up//')"
  printf '    mem available: %s MiB\n' "$(mem_available_mib)"
  printf '    disk %s: %s free\n' "$GRAVE_ROOT" "$(df -h "$GRAVE_ROOT" | awk 'NR==2{print $4}')"
  if command -v sensors >/dev/null; then
    sensors 2>/dev/null | awk '/^Package id 0|^Tctl|junction|^edge/ {printf "    temp %s\n", $0}' | head -3
  fi
}

# ------------------------------------------------------------- start/stop ----
start_dev() {
  need_root_helper
  say "Starting developer services..."
  dkctl start docker
  local stack
  for stack in "${DEV_STACKS[@]}"; do
    compose "$stack" up -d --wait 2>/dev/null || compose "$stack" up -d
    ok "stack $stack"
  done
  local s
  for s in "${DEV_SERVICES[@]}"; do sudo systemctl start "$s"; ok "$s"; done
  log "developer mode: started"
}

# Agent freeze uses the cgroup v2 freezer, NOT SIGSTOP: the tmux server
# SIGCONTs any stopped pane child (see tmux server_child_stopped), so signals
# silently lose. The kernel freezer is signal-proof — frozen tasks never run.
TORPOR_CG=/sys/fs/cgroup/grave-torpor

collect_tree() { # collect_tree <pid> -> appends pid + descendants to ALL_PIDS
  local pid="$1" c
  ALL_PIDS+=("$pid")
  for c in $(ps -o pid= --ppid "$pid" 2>/dev/null); do collect_tree "$c"; done
}

freeze_agents() {
  local pids p n=0
  pids=$(tmuxa list-panes -a -F '#{pane_pid}' 2>/dev/null) || return 0
  [[ -z "$pids" ]] && return 0
  sudo mkdir -p "$TORPOR_CG"
  ALL_PIDS=()
  for p in $pids; do collect_tree "$p"; n=$((n+1)); done
  for p in "${ALL_PIDS[@]}"; do
    echo "$p" | sudo tee "$TORPOR_CG/cgroup.procs" >/dev/null 2>&1 || true
  done
  echo 1 | sudo tee "$TORPOR_CG/cgroup.freeze" >/dev/null
  ok "froze $n agent pane(s) 🧊 (cgroup freezer: RAM kept, zero CPU — 'grave developer' thaws)"
}

thaw_agents() {
  [[ -f "$TORPOR_CG/cgroup.freeze" ]] || return 0
  [[ "$(cat "$TORPOR_CG/cgroup.freeze")" == 1 ]] || return 0
  echo 0 | sudo tee "$TORPOR_CG/cgroup.freeze" >/dev/null
  ok "thawed agent sessions"
}

stop_dev() { # stop_dev [kill]  — kill: also destroy tmux sessions (max free RAM)
  local kill_sessions="${1:-}"
  need_root_helper
  say "Stopping developer services..."
  local s
  for s in "${DEV_SERVICES[@]}"; do sudo systemctl stop "$s" 2>/dev/null || true; ok "stopped $s"; done
  if [[ "$kill_sessions" == kill ]]; then
    if tmuxa list-sessions >/dev/null 2>&1; then
      tmuxa kill-server 2>/dev/null || true
      ok "killed agent tmux sessions ☠️"
    fi
  else
    freeze_agents
  fi
  if dkctl is-active --quiet docker; then
    local stack idx
    for (( idx=${#DEV_STACKS[@]}-1; idx>=0; idx-- )); do
      stack="${DEV_STACKS[$idx]}"
      compose "$stack" stop 2>/dev/null || true
      ok "stopped stack $stack"
    done
    # stop any remaining containers so docker can shut down cleanly
    local rest; rest=$(dk ps -q)
    [[ -n "$rest" ]] && dk stop $rest >/dev/null
    dkctl stop docker.service; dkctl stop docker.socket 2>/dev/null || true
    ok "stopped docker"
  fi
  log "developer mode: stopped"
}

cmd_gaming() { # cmd_gaming [--kill]
  local tier=pause
  [[ "${1:-}" == "--kill" ]] && tier=kill
  local before after
  before=$(mem_available_mib)
  if [[ "$tier" == kill ]]; then stop_dev kill; else stop_dev; fi
  after=$(mem_available_mib)
  say ""
  if [[ "$tier" == kill ]]; then
    say "${BLD}🎮 Gaming mode (full kill).${RST} Freed ~$(( after - before )) MiB RAM. Agent sessions are gone."
  else
    say "${BLD}🎮 Gaming mode (torpor).${RST} Freed ~$(( after - before )) MiB RAM."
    say "Agent sessions are frozen in place — 'grave developer' thaws them."
  fi
  say "Remote access (Tailscale + SSH) is untouched."
  log "gaming mode: active ($tier, freed $(( after - before )) MiB)"
}

cmd_developer() {
  thaw_agents
  start_dev
  say ""
  say "${BLD}💻 Developer mode.${RST} All services up. 'grave status' for details."
  log "developer mode: active"
}

# ---------------------------------------------------------------- agents ----
cmd_agents() {
  local sub="${1:-list}"; shift || true
  case "$sub" in
    list)
      tmuxa list-sessions 2>/dev/null || say "No agent sessions. Start one: grave agents new <name> [dir]" ;;
    new)
      local name="${1:?usage: grave agents new <name> [dir]}"
      local dir="${2:-$GRAVE_ROOT/repos}"
      tmuxa -f "$TMUX_CONF" new-session -d -s "$name" -c "$dir"
      mkdir -p "$GRAVE_ROOT/agents/$name"
      tmuxa pipe-pane -t "$name" -o "cat >> $GRAVE_ROOT/agents/$name/session-\$(date +%%Y%%m%%d).log" 2>/dev/null || true
      ok "session '$name' created in $dir (attach: grave agents attach $name)" ;;
    attach)
      exec tmux -L "$TMUX_SOCKET" attach -t "${1:?usage: grave agents attach <name>}" ;;
    kill)
      tmuxa kill-session -t "${1:?usage: grave agents kill <name>}"; ok "killed ${1}" ;;
    *) say "usage: grave agents [list|new|attach|kill]"; exit 1 ;;
  esac
}

# ---------------------------------------------------------------- docker ----
cmd_docker() {
  local sub="${1:-ps}"; shift || true
  case "$sub" in
    ps)    dk ps -a --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' ;;
    up)    compose "${1:?stack name}" up -d ;;
    down)  compose "${1:?stack name}" down ;;
    logs)  dk logs --tail 100 -f "${1:?container name}" ;;
    stacks) ls -1 "$GRAVE_ROOT/docker" ;;
    disk)  dk system df ;;
    *) say "usage: grave docker [ps|up <stack>|down <stack>|logs <container>|stacks|disk]"; exit 1 ;;
  esac
}

# --------------------------------------------------------------- preview ----
# Expose a running dev server to the tailnet over HTTPS at the ROOT of its own
# port — NOT behind a path. A path prefix (/preview) breaks any framework that
# assumes it lives at "/" : Vite/Next HMR websockets, /@vite, /_next, absolute
# asset URLs all 404. Serving at the port root means the dev server works
# unmodified, no per-project base-path config. The server stays bound to
# 127.0.0.1; Tailscale terminates TLS and proxies over the tailnet ONLY (this
# is `serve`, not `funnel` — nothing is exposed to the public internet).
# Ports are confined to PREVIEW_RANGE so a preview can never shadow a platform
# service (4711-4713) or anything outside the sandbox.
tailnet_host() { tailscale status --json 2>/dev/null | sed -n 's/.*"DNSName": *"\([^"]*\)\.".*/\1/p' | head -1; }

preview_reserved() { # preview_reserved <port>  — a platform service sits on it
  local p="$1" r
  for r in ${PREVIEW_RESERVED:-}; do [[ "$p" == "$r" ]] && return 0; done
  return 1
}

preview_in_range() { # preview_in_range <port>  — valid, non-reserved preview port
  local p="$1" lo="${PREVIEW_RANGE%-*}" hi="${PREVIEW_RANGE#*-}"
  [[ "$p" =~ ^[0-9]+$ ]] && (( p >= lo && p <= hi )) && ! preview_reserved "$p"
}

port_listening() { # port_listening <port>  — something bound to it right now?
  ss -tlnH 2>/dev/null | awk '{print $4}' | grep -qE "[:.]$1\$"
}

listening_previews() { # previewable ports with a live listener (one per line)
  local p
  ss -tlnH 2>/dev/null | awk '{print $4}' | sed -n 's/.*[:.]\([0-9]\{1,\}\)$/\1/p' | sort -un |
    while read -r p; do preview_in_range "$p" && echo "$p"; done
}

preview_start() { # preview_start <port>
  local port="$1" host
  preview_reserved "$port" && { bad "port $port belongs to a platform service — refusing to expose it"; exit 1; }
  preview_in_range "$port" || { bad "port $port is outside the preview range $PREVIEW_RANGE"; exit 1; }
  host=$(tailnet_host)
  [[ -n "$host" ]] || { bad "can't read the tailnet name — is tailscale up?"; exit 1; }
  if ! port_listening "$port"; then
    say "  ${YLW}nothing is listening on 127.0.0.1:$port yet — start your dev server first (this maps it anyway).${RST}"
  fi
  tailscale serve --bg --https="$port" "http://127.0.0.1:$port" >/dev/null
  log "preview: on $port"
  ok "https://$host:$port  →  127.0.0.1:$port  (tailnet only — 'grave preview off $port' to stop)"
}

preview_stop() { # preview_stop <port>
  local port="$1"
  preview_in_range "$port" || { bad "port $port is outside the preview range $PREVIEW_RANGE"; exit 1; }
  tailscale serve --https="$port" off >/dev/null 2>&1 || true
  log "preview: off $port"
  ok "preview on $port stopped"
}

cmd_preview() { # grave preview [<port>|off <port>|list]
  local sub="${1:-}"; shift || true
  case "$sub" in
    ""|auto)
      # No port: expose the single dev server listening in range. If several
      # are up we can't guess — list them and ask for an explicit port.
      local ports; mapfile -t ports < <(listening_previews)
      case "${#ports[@]}" in
        0) say "No dev server is listening in $PREVIEW_RANGE. Start one, then:"
           say "  grave preview <port>"; exit 1 ;;
        1) preview_start "${ports[0]}" ;;
        *) say "Several dev servers are listening — name the port:"
           local p; for p in "${ports[@]}"; do say "  grave preview $p"; done; exit 1 ;;
      esac ;;
    off|stop) preview_stop "${1:?usage: grave preview off <port>}" ;;
    list|status|ls)
      local host line port any=0; host=$(tailnet_host)
      while IFS= read -r line; do
        port=$(sed -n 's#^https://[^ :]*:\([0-9]\{1,\}\).*#\1#p' <<<"$line")
        [[ -n "$port" ]] && preview_in_range "$port" && { say "  https://$host:$port  →  127.0.0.1:$port"; any=1; }
      done < <(tailscale serve status 2>/dev/null)
      (( any )) || say "  (no previews active)" ;;
    *)
      if [[ "$sub" =~ ^[0-9]+$ ]]; then preview_start "$sub"  # start (validates range/reserved)
      else say "usage: grave preview [<port>|off <port>|list]"; exit 1; fi ;;
  esac
}

# ---------------------------------------------------------------- update ----
cmd_update() {
  need_root_helper
  if command -v snapper >/dev/null; then
    say "Snapshotting before update..."
    sudo snapper -c root create --description "grave-pre-update" --cleanup-algorithm number || true
  fi
  if [[ "${CHECK_IMMUTABLE_ROOT:-0}" == 1 ]]; then
    # Immutable rootfs (e.g. stock SteamOS): never pacman into read-only /usr —
    # it won't survive an OS update. The durable toolchain updates via Homebrew
    # under $HOME; the base OS updates through its own image updater. See
    # docs/STEAMOS.md.
    if command -v brew >/dev/null; then
      say "Updating Homebrew toolchain..."
      brew update >/dev/null 2>&1 && brew upgrade 2>&1 | tail -1 || say "${YLW}brew upgrade had issues (non-fatal)${RST}"
    fi
    say "${YLW}base OS is image-based — update it with the system updater, not grave${RST}"
  else
    say "Updating system packages..."
    case "$(pkg_mgr)" in
      pacman) sudo pacman -Syu --noconfirm
              if command -v paru >/dev/null; then paru -Sua --noconfirm || say "${YLW}AUR update had issues (non-fatal)${RST}"; fi ;;
      apt)    sudo apt-get update && sudo apt-get -y upgrade ;;
      dnf)    sudo dnf -y upgrade ;;
      *)      say "${YLW}no known package manager — skipping system update${RST}" ;;
    esac
    if ((${#NPM_GLOBAL_TOOLS[@]})); then
      say "Updating npm-global tools..."
      sudo npm update -g "${NPM_GLOBAL_TOOLS[@]}" 2>&1 | tail -1 || true
    fi
  fi
  say "Checking T3 Code..."
  cmd_t3 update
  if dkctl is-active --quiet docker; then
    say "Pulling docker images..."
    local stack; for stack in "${DEV_STACKS[@]}"; do compose "$stack" pull -q || true; done
  fi
  say "Agent CLIs (claude/codex) self-update on launch."
  log "update: completed"
  ok "update complete — reboot only if the kernel changed"
}

# -------------------------------------------------------------- bootmode ----
cmd_bootmode() { # what the box boots into: developer (dev services up) or gaming
  case "${1:-}" in
    "")
      if systemctl is-enabled --quiet t3code 2>/dev/null; then
        say "boot mode: developer (dev services start at boot)"
      else
        say "boot mode: gaming (dev services stay down until 'grave developer')"
      fi ;;
    developer|dev)
      need_root_helper
      sudo systemctl enable t3code >/dev/null 2>&1 || true
      dkctl enable docker >/dev/null 2>&1 || true   # rootless: per-user unit
      ok "boot mode: developer — dev services start automatically after reboot" ;;
    gaming|game)
      need_root_helper
      sudo systemctl disable t3code >/dev/null 2>&1 || true
      dkctl disable docker docker.socket >/dev/null 2>&1 || true
      ok "boot mode: gaming — after reboot only ALWAYS_ON runs; 'grave developer' wakes the rest" ;;
    *) say "usage: grave bootmode [developer|gaming]"; exit 1 ;;
  esac
}

# ------------------------------------------------------------- gamewatch ----
# Game-mode auto-throttle toggle. The gravedecay-gamewatch.service loop watches
# for a running game and flips grave gaming/developer; this just flips the flag
# file it reads each poll (no sudo — the file lives under $GRAVE_ROOT).
cmd_gamewatch() {
  local flag="$GRAVE_ROOT/config/gamewatch.on"
  case "${1:-status}" in
    on)  mkdir -p "$GRAVE_ROOT/config"; : > "$flag"
         ok "auto-throttle ON — launching a game freezes agents; 'grave gamewatch off' to stop" ;;
    off) rm -f "$flag"; ok "auto-throttle OFF (games no longer flip modes)" ;;
    status)
      [[ -e "$flag" ]] && say "auto-throttle: ${GRN}on${RST}" || say "auto-throttle: ${YLW}off${RST}"
      if systemctl is-active --quiet gravedecay-gamewatch; then say "  watcher service: running"
      else say "  watcher service: ${YLW}stopped${RST} (install via raise.sh --profile steam-machine)"; fi
      [[ -r "$GRAVE_ROOT/logs/gamewatch.state" ]] && say "  last seen: $(cat "$GRAVE_ROOT/logs/gamewatch.state")" ;;
    *) say "usage: grave gamewatch [on|off|status]"; exit 1 ;;
  esac
}

# --------------------------------------------------------------- upgrade ----
cmd_upgrade() { # grave upgrade [--edge|--release] — update gravedecay itself
  local channel="${UPGRADE_CHANNEL:-release}"
  local repo="${REPO_DIR:-$GRAVE_ROOT/repos/gravedecay}"
  case "${1:-}" in
    --edge) channel=edge ;;
    --release) channel=release ;;
    "") ;;
    *) say "usage: grave upgrade [--edge|--release]"; exit 1 ;;
  esac
  [[ -d "$repo/.git" ]] || { bad "gravedecay checkout not found at $repo (set REPO_DIR in grave.conf)"; exit 1; }
  if [[ -n "$(git -C "$repo" status --porcelain)" ]]; then
    bad "checkout at $repo has local changes — commit or stash them first"
    exit 1
  fi
  say "Fetching updates (${channel} channel)..."
  git -C "$repo" fetch --tags --prune -q origin
  git -C "$repo" remote set-head origin -a >/dev/null 2>&1 || true
  local target=""
  if [[ "$channel" == release ]]; then
    target=$(git -C "$repo" tag -l 'v*' --sort=-v:refname | head -1)
    if [[ -z "$target" ]]; then
      say "${YLW}no release tags found — following main instead${RST}"
      channel=edge
    fi
  fi
  if [[ "$channel" == edge ]]; then
    local branch
    branch=$(git -C "$repo" symbolic-ref -q --short refs/remotes/origin/HEAD || echo origin/master)
    branch=${branch#origin/}
    git -C "$repo" checkout -q "$branch"
    git -C "$repo" pull -q --ff-only origin "$branch"
    target="$branch"
  else
    git -C "$repo" checkout -q --detach "$target"
  fi
  ok "checked out $target ($(git -C "$repo" rev-parse --short HEAD))"
  say "Re-running the ritual (idempotent)..."
  bash "$repo/raise.sh"
  log "upgrade: $target"
}

# ------------------------------------------------------------------ logs ----
cmd_logs() {
  local target="${1:-grave}"
  case "$target" in
    t3|t3code)  sudo journalctl -u t3code -n 100 -f ;;
    dash|gravedecay) sudo journalctl -u gravedecay -n 100 -f ;;
    term)       sudo journalctl -u gravedecay-term -n 100 -f ;;
    ssh|sshd)   sudo journalctl -u sshd -n 100 -f ;;
    tailscale)  sudo journalctl -u tailscaled -n 100 -f ;;
    system)     sudo journalctl -p warning -n 100 -f ;;
    grave)      tail -n 50 -f "$LOG_FILE" ;;
    agent)      tail -n 100 -f "$GRAVE_ROOT"/agents/"${2:?agent name}"/session-*.log ;;
    *)          dk logs --tail 100 -f "$target" 2>/dev/null || \
                sudo journalctl -u "$target" -n 100 -f ;;
  esac
}

# ---------------------------------------------------------------- doctor ----
check() { # check <description> <command...>
  if "${@:2}" >/dev/null 2>&1; then ok "$1"; else bad "$1"; FAILURES=$((FAILURES+1)); fi
}
firewall_active() {
  if command -v ufw >/dev/null; then sudo ufw status | grep -q "Status: active"
  elif command -v firewall-cmd >/dev/null; then firewall-cmd --state >/dev/null 2>&1
  else return 1; fi
}
cmd_doctor() {
  FAILURES=0
  hdr "grave doctor"
  check "tailscaled running"            systemctl is-active --quiet tailscaled
  check "tailscale logged in"           tailscale status --peers=false
  check "sshd running"                  systemctl is-active --quiet sshd
  if [[ "${CHECK_FIREWALL:-1}" == 1 ]]; then
    check "firewall active"             firewall_active
  else
    say "  ${YLW}– firewall check relaxed (LAN kept open for gaming; boundary is 127.0.0.1 + tailnet)${RST}"
  fi
  check "ssh password auth disabled"    bash -c "sudo sshd -T | grep -qi 'passwordauthentication no'"
  if [[ "${CHECK_SLEEP_MASKED:-0}" == 1 ]]; then
    check "sleep targets masked"        bash -c '[[ $(systemctl is-enabled sleep.target) == masked ]]'
  fi
  if [[ "${CHECK_LID_IGNORED:-0}" == 1 ]]; then
    check "lid switch ignored"          bash -c '[[ $(busctl get-property org.freedesktop.login1 /org/freedesktop/login1 org.freedesktop.login1.Manager HandleLidSwitch) == *ignore* ]]'
  fi
  if [[ "${CHECK_DOCKER_SUBVOL:-0}" == 1 ]]; then
    check "/var/lib/docker on own subvol" bash -c 'findmnt -n /var/lib/docker | grep -q subvol'
  fi
  if [[ "${CHECK_SNAPPER:-0}" == 1 ]]; then
    check "snapper config for GRAVE_ROOT" sudo snapper -c "${SNAPPER_CONFIG:-srv}" list
  fi
  if [[ "${CHECK_IMMUTABLE_ROOT:-0}" == 1 ]]; then
    # On an image-based rootfs (SteamOS) an OS update replaces /usr. Everything
    # we rely on must therefore live off the root mount, or it silently vanishes.
    check "GRAVE_ROOT off the immutable root mount" \
      bash -c "[[ \"\$(findmnt -no TARGET --target '$GRAVE_ROOT')\" != / ]]"
    check "durable toolchain under \$HOME (Homebrew)" command -v brew
    check "Docker is rootless (survives OS updates)" \
      bash -c "[[ '${DOCKER_ROOTLESS:-0}' == 1 ]]"
    # /etc drift after a SteamOS update — the self-heal boot unit drops this
    # marker when a config file it depends on went missing (see docs/STEAMOS.md).
    if [[ -f "$GRAVE_ROOT/logs/DRIFT-DETECTED" ]]; then
      bad "config drift after OS update — re-run raise.sh (see $GRAVE_ROOT/logs/selfheal.log)"
      FAILURES=$((FAILURES+1))
    fi
  fi
  # --- reboot-readiness: "active" isn't "enabled". A unit that's running now
  # but not enabled won't come back after a reboot, so surviving a reboot is
  # only real if these pass. (Doctor is the contract.)
  local u
  for u in "${ALWAYS_ON[@]}" "${DEV_SERVICES[@]}"; do
    systemctl cat "$u.service" >/dev/null 2>&1 || continue   # unit not on this host
    check "$u enabled (starts at boot)"  systemctl is-enabled --quiet "$u"
  done
  if [[ "${DOCKER_ROOTLESS:-0}" == 1 ]]; then
    check "rootless docker enabled at boot"   systemctl --user is-enabled --quiet docker
    check "linger on (user services start without login)" \
      bash -c "loginctl show-user \"\$(id -un)\" 2>/dev/null | grep -q 'Linger=yes'"
  fi
  if [[ -e "$GRAVE_ROOT/config/gamewatch.on" ]]; then
    check "game-mode watcher running"   systemctl is-active --quiet gravedecay-gamewatch
    check "game-mode watcher enabled"   systemctl is-enabled --quiet gravedecay-gamewatch
  fi
  if dkctl is-active --quiet docker; then
    check "docker healthy"              dk info
    # dk is a shell function, so expand the real argv for the piped subshell
    check "no LAN-exposed containers"   bash -c "! ${_DOCKER[*]} ps --format '{{.Ports}}' | grep -E '0\.0\.0\.0|\[::\]'"
  else
    say "  ${YLW}– docker stopped (gaming mode?)${RST}"
  fi
  if systemctl is-active --quiet t3code; then
    check "t3 CLI runs"                   t3 --version
    check "t3code answering"            curl -sf -o /dev/null "http://127.0.0.1:$T3_PORT/"
  else
    say "  ${YLW}– t3code stopped (gaming mode?)${RST}"
  fi
  if systemctl is-active --quiet gravedecay; then
    check "gravedecay answering"         curl -sf -o /dev/null "http://127.0.0.1:$DASH_PORT/healthz"
  else
    say "  ${YLW}– gravedecay stopped${RST}"
  fi
  if systemctl is-active --quiet gravedecay-term; then
    check "web terminal answering"       curl -sf -o /dev/null "http://127.0.0.1:${TERM_PORT:-4713}/"
  else
    say "  ${YLW}– web terminal stopped${RST}"
  fi
  check "backups dir writable"          test -w "$BACKUP_DIR"
  echo
  if (( FAILURES == 0 )); then say "${GRN}${BLD}All checks passed.${RST}"; else say "${RED}${BLD}$FAILURES check(s) failed.${RST}"; exit 1; fi
}

# ---------------------------------------------------------------- backup ----
cmd_backup() {
  need_root_helper
  local ts dest; ts=$(date +%Y%m%d-%H%M%S); dest="$BACKUP_DIR/$ts"
  mkdir -p "$dest"/{repos,volumes,configs}
  say "Backing up to $dest"

  local repo name
  for repo in "$GRAVE_ROOT"/repos/*/; do
    [[ -d "$repo/.git" ]] || continue
    name=$(basename "$repo")
    git -C "$repo" bundle create "$dest/repos/$name.bundle" --all 2>/dev/null && ok "repo $name (git bundle)"
  done

  tar -C "$GRAVE_ROOT" -czf "$dest/configs/grave-platform.tar.gz" config docker docs scripts 2>/dev/null && ok "platform config"
  local d
  for d in "${AGENT_CONFIG_DIRS[@]}"; do
    [[ -e "$HOME/$d" ]] && tar -C "$HOME" -czf "$dest/configs/${d#.}.tar.gz" "$d" 2>/dev/null && ok "agent config $d"
  done
  [[ -d "$GRAVE_ROOT/agents/t3code" ]] && tar -C "$GRAVE_ROOT/agents" -czf "$dest/configs/t3code-state.tar.gz" t3code && ok "t3code state"

  if dkctl is-active --quiet docker; then
    local vol
    for vol in $(dk volume ls -q | grep -vE '^[0-9a-f]{64}$'); do
      dk run --rm -v "$vol":/data:ro -v "$dest/volumes":/backup alpine \
        tar -czf "/backup/$vol.tar.gz" -C /data . && ok "volume $vol"
    done
  else
    say "  ${YLW}docker stopped — volumes skipped this run${RST}"
  fi

  # retention
  local old
  while IFS= read -r old; do
    rm -rf "$BACKUP_DIR/${old:?}"; say "  pruned old backup $old"
  done < <(ls -1 "$BACKUP_DIR" | sort | head -n -"$BACKUP_KEEP")
  log "backup: $ts complete"
  ok "backup complete: $dest"
}

cmd_restore() {
  local ts="${1:-}"
  if [[ -z "$ts" ]]; then
    hdr "Available backups"
    ls -1 "$BACKUP_DIR" 2>/dev/null || say "(none)"
    say ""
    say "usage: grave restore <backup> [volume <name> | repo <name>]"
    say "Full procedures: $GRAVE_ROOT/docs/RECOVERY.md"
    return
  fi
  local dest="$BACKUP_DIR/$ts"
  [[ -d "$dest" ]] || { bad "no such backup: $ts"; exit 1; }
  case "${2:-}" in
    volume)
      local vol="${3:?volume name}"
      dk volume create "$vol" >/dev/null
      dk run --rm -v "$vol":/data -v "$dest/volumes":/backup:ro alpine \
        sh -c "cd /data && tar -xzf /backup/$vol.tar.gz"
      ok "volume $vol restored from $ts" ;;
    repo)
      local name="${3:?repo name}"
      git clone "$dest/repos/$name.bundle" "$GRAVE_ROOT/repos/$name-restored"
      ok "repo restored to $GRAVE_ROOT/repos/$name-restored" ;;
    *)
      say "Backup contents of $ts:"; find "$dest" -type f | sed "s|$dest/|  |"
      say ""; say "Restore a piece: grave restore $ts volume <name> | repo <name>"
      say "Full procedures: $GRAVE_ROOT/docs/RECOVERY.md" ;;
  esac
}

# ------------------------------------------------------------------ help ----
cmd_help() {
  cat <<'EOF'
grave — gravedecay appliance control 🪦

  grave status               overview: services, containers, agents, system
  grave doctor               verify every platform invariant

  grave gaming               🎮 free resources: stop services, FREEZE agent
                             sessions in place (🧊 torpor — RAM kept, zero CPU)
  grave gaming --kill        ☠️ same but destroy agent sessions (max free RAM)
  grave developer            💻 thaw sessions + restore full development mode
  grave start | stop         same as developer / gaming (without the banner)
  grave restart              stop + start developer services

  grave agents               list agent tmux sessions
  grave agents new <n> [dir]    create persistent agent session
  grave agents attach <n>       attach (detach: Ctrl-b d)
  grave agents kill <n>         kill session

  grave docker [ps|up <stack>|down <stack>|logs <c>|stacks|disk]
  grave logs [t3|dash|ssh|tailscale|system|grave|agent <n>|<container/unit>]

  grave preview <port>       expose a running dev server (e.g. :3000) to the
                             tailnet at https://<box>.ts.net:<port> — root path,
                             so HMR/websockets just work. Server stays loopback.
  grave preview              auto-pick the one dev server listening in the range
  grave preview list         show active previews
  grave preview off <port>   stop a preview

  grave t3 [status|update]   show versions or install npm's stable T3 release
  grave update               snapshot (if snapper), update pkgs/npm/images
  grave upgrade              update gravedecay itself: pull latest release
                             (or --edge for main), re-run the ritual
  grave bootmode [dev|game]  what a reboot boots into: developer services
                             up (default) or gaming (ALWAYS_ON only)
  grave gamewatch [on|off]   auto gaming/developer flip when a game launches
                             (Steam Machine); 'status' to check
  grave backup               bundle repos, configs, docker volumes
  grave restore [backup]     list / restore backups

Docs: $GRAVE_ROOT/docs   Config: /etc/gravedecay/grave.conf
EOF
}

# ------------------------------------------------------------------ main ----
case "${1:-help}" in
  status)     cmd_status ;;
  gaming)     shift || true; cmd_gaming "$@" ;;
  developer)  cmd_developer ;;
  start)      start_dev ;;
  stop)       shift || true; stop_dev "$@" ;;
  restart)    stop_dev; thaw_agents; start_dev ;;
  agents)     shift; cmd_agents "$@" ;;
  docker)     shift; cmd_docker "$@" ;;
  preview)    shift || true; cmd_preview "$@" ;;
  t3|t3code)  shift || true; cmd_t3 "$@" ;;
  update)     cmd_update ;;
  upgrade)    shift || true; cmd_upgrade "$@" ;;
  bootmode)   shift || true; cmd_bootmode "$@" ;;
  gamewatch)  shift || true; cmd_gamewatch "$@" ;;
  logs)       shift; cmd_logs "$@" ;;
  doctor)     cmd_doctor ;;
  backup)     cmd_backup ;;
  restore)    shift || true; cmd_restore "$@" ;;
  help|--help|-h) cmd_help ;;
  *) say "unknown command: $1"; cmd_help; exit 1 ;;
esac
