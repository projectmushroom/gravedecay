#!/usr/bin/env bash
# grave — unified control tool for a gravedecay appliance.
# Docs: $GRAVE_ROOT/docs (or the gravedecay repo)   Config: /etc/gravedecay/grave.conf
set -euo pipefail

CONF="${GRAVE_CONF:-/etc/gravedecay/grave.conf}"
[[ -r "$CONF" ]] || { echo "grave: config not found at $CONF (run raise.sh first)"; exit 1; }
# shellcheck disable=SC1090
source "$CONF"

# On a managed-toolchain host (Homebrew + rootless docker under $HOME) the tools
# grave shells out to — docker, tailscale, tmux — aren't on a bare login PATH.
# TOOL_PATH (set by raise.sh; empty on package-manager hosts) makes grave
# self-sufficient regardless of how it was invoked.
[[ -n "${TOOL_PATH:-}" ]] && export PATH="$TOOL_PATH$PATH"

# Tailnet port range for `grave preview` (dev-server tunnels), and any platform
# ports that fall inside it and must never be exposed (Playwright is on 3050).
# Defaults here so installs whose grave.conf predates the feature still work;
# documented in docs/PORTS.md and grave.conf.example.
: "${PREVIEW_RANGE:=3000-3999}"
: "${PREVIEW_RESERVED:=3050}"
: "${MULTI_USER:=0}"

# Doctor fails when the newest verified backup is older than this (#112).
# Default here so installs whose grave.conf predates the feature still work;
# documented in docs/RECOVERY.md and grave.conf.example.
: "${BACKUP_MAX_AGE_DAYS:=2}"

# Event classes allowed to page the human via `grave notify --event` (#78).
# Default here so installs whose grave.conf predates the feature still work;
# documented in docs/NOTIFICATIONS.md and grave.conf.example. The dashboard's
# ⚙️ checkboxes write an override file (it runs unprivileged and must not need
# sudo for a notification preference — same reasoning as the gamewatch flag),
# which wins over the conf value when present.
: "${NOTIFY_EVENTS:=session-exit bell agent-done unit-failure doctor digest}"
[[ -r "$GRAVE_ROOT/config/notify-events" ]] && NOTIFY_EVENTS="$(<"$GRAVE_ROOT/config/notify-events")"

LOG_FILE="$GRAVE_ROOT/logs/grave.log"
NOTIFY_ENV="$GRAVE_ROOT/config/secrets/notify.env"
PUSH_SUBS="$GRAVE_ROOT/config/push-subscriptions.json"
AGENT_NOTIFY="$GRAVE_ROOT/scripts/grave-agent-notify"
GAMEWATCH_PREFERENCE="$GRAVE_ROOT/config/gamewatch.preference"
AUTO_THAW_UNIT="gravedecay-auto-thaw"
AUTO_THAW_TIMER="$AUTO_THAW_UNIT.timer"
RED=$'\e[31m'; GRN=$'\e[32m'; YLW=$'\e[33m'; BLD=$'\e[1m'; RST=$'\e[0m'

log() { { printf '%s %s\n' "$(date '+%F %T')" "$*" >> "$LOG_FILE"; } 2>/dev/null || true; }
say() { printf '%s\n' "$*"; }
ok()  { printf '  %b✓%b %s\n' "$GRN" "$RST" "$*"; }
bad() { printf '  %b✗%b %s\n' "$RED" "$RST" "$*"; }
hdr() { printf '\n%b%s%b\n' "$BLD" "$*" "$RST"; }

need_root_helper() { [[ $EUID == 0 ]] && return; sudo -n systemctl --version >/dev/null 2>&1 || { say "grave needs passwordless sudo for this (see docs/SECURITY.md)"; exit 1; }; }

tmuxa() { tmux -L "$TMUX_SOCKET" "$@"; }
workspace_services() {
  [[ "${MULTI_USER:-0}" == 1 && -r "$GRAVE_ROOT/config/workspaces.json" ]] || return 0
  jq -r '.workspaces[] | select(.enabled) | .slug' "$GRAVE_ROOT/config/workspaces.json" | while read -r slug; do
    printf '%s\n' "gravedecay-t3@$slug" "gravedecay-term@$slug" "gravedecay-dashboard@$slug"
  done
}

# Container engine: rootless Docker (per-user, no sudo — durable on immutable
# hosts like SteamOS) vs system Docker (sudo). dk = the docker CLI, dkctl =
# how we manage the docker unit (per-user vs system systemd). Everything else
# in grave calls these two, so the sudo/rootless split lives in one place.
if [[ "${DOCKER_ROOTLESS:-0}" == 1 ]]; then
  export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
  [[ -n "${DOCKER_HOST:-}" ]] && export DOCKER_HOST
  _DOCKER=(docker);      _DKCTL=(systemctl --user)
else
  _DOCKER=(sudo docker); _DKCTL=(sudo systemctl)
fi
dk()    { "${_DOCKER[@]}" "$@"; }
dkctl() { "${_DKCTL[@]}"  "$@"; }

compose() { # compose <stack> <args...>
  local stack="$1"; shift
  dk compose --project-directory "$GRAVE_ROOT/docker/$stack" "$@"
}

mem_available_mib() { awk '/MemAvailable/ {print int($2/1024)}' /proc/meminfo; }

auto_thaw_active() {
  systemctl is-active --quiet "$AUTO_THAW_TIMER"
}

cancel_auto_thaw() {
  auto_thaw_active || return 0
  need_root_helper
  sudo systemctl stop "$AUTO_THAW_TIMER" >/dev/null 2>&1 || true
  ok "cancelled pending gaming auto-thaw"
}

schedule_auto_thaw() { # schedule_auto_thaw <systemd timespan, e.g. 2h or 90m>
  local duration="$1" grave_bin
  systemd-analyze timespan "$duration" >/dev/null 2>&1 \
    || { bad "invalid --for duration '$duration' (examples: 30m, 2h, 1h30m)"; exit 1; }
  command -v systemd-run >/dev/null 2>&1 \
    || { bad "systemd-run is required for --for"; exit 1; }
  need_root_helper
  grave_bin="$(readlink -f "$0")"
  # Re-enter the already-authorized grave root helper instead of broadening the
  # sudoers surface to systemd-run. Existing boxes can use --for immediately
  # after a headless upgrade, even before their next interactive sudoers refresh.
  sudo -n "$grave_bin" __auto-thaw schedule "$duration"
}

cmd_auto_thaw_root() { # root-only helper: cmd_auto_thaw_root schedule <timespan>
  [[ $EUID == 0 ]] || { bad "auto-thaw root helper must run through sudo"; exit 1; }
  local sub="${1:-}" duration="${2:-}" uid="${SUDO_UID:-}" gid="${SUDO_GID:-}"
  [[ "$sub" == schedule && "$uid" =~ ^[0-9]+$ && "$gid" =~ ^[0-9]+$ ]] \
    || { bad "invalid auto-thaw helper invocation"; exit 1; }
  systemd-analyze timespan "$duration" >/dev/null 2>&1 \
    || { bad "invalid auto-thaw duration"; exit 1; }
  local user home grave_bin
  user="$(getent passwd "$uid" | cut -d: -f1)"
  home="$(getent passwd "$uid" | cut -d: -f6)"
  [[ -n "$user" && -n "$home" ]] || { bad "cannot resolve auto-thaw owner"; exit 1; }
  grave_bin="$(readlink -f "$0")"
  # A system transient timer survives the invoking shell/dashboard request. The
  # service itself runs as the appliance owner so rootless Docker and the user
  # tmux session are restored in the same context as an interactive command.
  /usr/bin/systemd-run --quiet --collect \
    --unit="$AUTO_THAW_UNIT" --on-active="$duration" \
    --timer-property=AccuracySec=1s \
    --description="Restore gravedecay developer mode after gaming" \
    --uid="$uid" --gid="$gid" --setenv="HOME=$home" \
    --setenv="USER=$user" --setenv="LOGNAME=$user" \
    "$grave_bin" developer
  ok "auto-thaw scheduled in $duration"
}

pkg_mgr() {
  if command -v pacman >/dev/null; then echo pacman
  elif command -v apt-get >/dev/null; then echo apt
  elif command -v dnf >/dev/null; then echo dnf
  else echo none; fi
}

t3_version() {
  t3 --version 2>/dev/null | sed -n 's/^t3 v//p' | head -1
}

t3_latest_version() {
  npm view t3 dist-tags.latest --silent 2>/dev/null | tail -1
}

cmd_t3() { # grave t3 [status|update] — inspect/update the stable T3 Code CLI
  local sub="${1:-status}" installed latest t3_bin npm_bin
  command -v t3 >/dev/null 2>&1 || { bad "t3 is not installed"; exit 1; }
  command -v npm >/dev/null 2>&1 || { bad "npm is not installed"; exit 1; }
  installed=$(t3_version)
  [[ -n "$installed" ]] || { bad "t3 is installed but does not run"; exit 1; }
  latest=$(t3_latest_version)
  [[ "$latest" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || {
    bad "could not resolve npm's stable t3 version"; exit 1;
  }

  case "$sub" in
    status)
      say "T3 Code: installed v$installed; stable v$latest"
      [[ "$installed" == "$latest" ]] && ok "T3 Code is up to date" || say "  update available — run: grave t3 update"
      ;;
    update)
      if [[ "$installed" == "$latest" ]]; then
        ok "T3 Code v$installed is already up to date"
        return
      fi
      say "Updating T3 Code v$installed → v$latest (stable)..."
      t3_bin=$(command -v t3)
      npm_bin=$(command -v npm)
      if [[ "$t3_bin" == "$HOME/.local/"* ]]; then
        # SteamOS: node-pty must be rebuilt against the pinned Node ABI using
        # the header wrappers created by steamos-toolchain.sh.
        local wrappers="$HOME/.local/toolchain-wrappers"
        PATH="$wrappers:$(dirname "$npm_bin"):$PATH" CC=cc CXX=c++ \
          "$npm_bin" install -g --prefix "$HOME/.local" "t3@$latest"
      else
        need_root_helper
        # Package-manager hosts install t3 system-wide. npm update follows the
        # package's stable latest tag; the exact result is validated below.
        sudo npm update -g t3
      fi
      local updated
      updated=$(t3_version)
      [[ "$updated" == "$latest" ]] || {
        bad "update validation failed: expected v$latest, found v${updated:-unknown}"
        exit 1
      }
      if [[ "${MULTI_USER:-0}" == 1 && -r "$GRAVE_ROOT/config/workspaces.json" ]]; then
        local slug port any=0
        while read -r slug port; do
          systemctl is-active --quiet "gravedecay-t3@$slug" || continue; any=1
          sudo -n systemctl restart "gravedecay-t3@$slug"
          curl -sf --retry 10 --retry-delay 1 -o /dev/null "http://127.0.0.1:$port/" || { bad "T3 workspace $slug did not answer"; exit 1; }
          ok "T3 workspace $slug answering after restart"
        done < <(jq -r '.workspaces[] | select(.enabled) | "\(.slug) \(.ports.t3)"' "$GRAVE_ROOT/config/workspaces.json")
        (( any )) || say "  workspace T3 services are stopped (gaming mode?) — they will use v$updated next start"
      elif systemctl is-active --quiet t3code; then
        sudo -n systemctl restart t3code
        if curl -sf --retry 10 --retry-delay 1 -o /dev/null \
            "http://127.0.0.1:$T3_PORT/"; then
          ok "t3code answering after restart"
        else
          bad "t3code did not answer after restart"
          exit 1
        fi
      else
        say "  t3code is stopped (gaming mode?) — it will use v$updated next start"
      fi
      log "t3: updated v$installed to v$updated"
      ok "T3 Code updated to v$updated"
      ;;
    *) say "usage: grave t3 [status|update]"; exit 1 ;;
  esac
}

# ---------------------------------------------------------------- status ----
cmd_status() {
  hdr "Always-on services"
  local s
  for s in "${ALWAYS_ON[@]}"; do
    if systemctl is-active --quiet "$s"; then ok "$s"; else bad "$s (inactive)"; fi
  done

  hdr "Developer services"
  for s in "${DEV_SERVICES[@]}"; do
    if systemctl is-active --quiet "$s"; then ok "$s"; else bad "$s (stopped)"; fi
  done
  if dkctl is-active --quiet docker; then
    ok "docker"
    dk ps --format '    {{.Names}}: {{.Status}}' 2>/dev/null || true
  else
    bad "docker (stopped)"
  fi

  hdr "Agent tmux sessions ($TMUX_SOCKET)"
  local sessions
  sessions=$(tmuxa list-sessions 2>/dev/null || true)
  if [[ -n "$sessions" ]]; then sed 's/^/    /' <<<"$sessions"; else say "    (none)"; fi

  hdr "Tailscale"
  if command -v tailscale >/dev/null && tailscale status --peers=false >/dev/null 2>&1; then
    tailscale status --peers=false | sed 's/^/    /'
  else
    bad "tailscale not connected"
  fi

  hdr "System"
  printf '    uptime:%s\n' "$(uptime -p | sed 's/^up//')"
  printf '    mem available: %s MiB\n' "$(mem_available_mib)"
  printf '    disk %s: %s free\n' "$GRAVE_ROOT" "$(df -h "$GRAVE_ROOT" | awk 'NR==2{print $4}')"
  if command -v sensors >/dev/null; then
    sensors 2>/dev/null | awk '/^Package id 0|^Tctl|junction|^edge/ {printf "    temp %s\n", $0}' | head -3
  fi

  if auto_thaw_active; then
    local deadline
    deadline="$(LC_ALL=C systemctl list-timers "$AUTO_THAW_TIMER" --no-legend --no-pager 2>/dev/null \
      | awk 'NF {print $1, $2, $3, $4; exit}')"
    hdr "Gaming auto-thaw"
    say "    pending${deadline:+; next: $deadline}"
  fi
}

# ------------------------------------------------------------- start/stop ----
start_dev() {
  need_root_helper
  say "Starting developer services..."
  dkctl start docker
  local stack
  for stack in "${DEV_STACKS[@]}"; do
    compose "$stack" up -d --wait 2>/dev/null || compose "$stack" up -d
    ok "stack $stack"
  done
  local s
  for s in "${DEV_SERVICES[@]}"; do sudo systemctl start "$s"; ok "$s"; done
  while read -r s; do [[ -n "$s" ]] && { sudo systemctl start "$s"; ok "$s"; }; done < <(workspace_services)
  log "developer mode: started"
}

# Agent freeze uses the cgroup v2 freezer, NOT SIGSTOP: the tmux server
# SIGCONTs any stopped pane child (see tmux server_child_stopped), so signals
# silently lose. The kernel freezer is signal-proof — frozen tasks never run.
TORPOR_CG=/sys/fs/cgroup/grave-torpor

collect_tree() { # collect_tree <pid> -> appends pid + descendants to ALL_PIDS
  local pid="$1" c
  ALL_PIDS+=("$pid")
  for c in $(ps -o pid= --ppid "$pid" 2>/dev/null); do collect_tree "$c"; done
}

freeze_agents() {
  local pids p n=0
  pids=$(tmuxa list-panes -a -F '#{pane_pid}' 2>/dev/null) || return 0
  [[ -z "$pids" ]] && return 0
  sudo mkdir -p "$TORPOR_CG"
  ALL_PIDS=()
  for p in $pids; do collect_tree "$p"; n=$((n+1)); done
  for p in "${ALL_PIDS[@]}"; do
    echo "$p" | sudo tee "$TORPOR_CG/cgroup.procs" >/dev/null 2>&1 || true
  done
  echo 1 | sudo tee "$TORPOR_CG/cgroup.freeze" >/dev/null
  ok "froze $n agent pane(s) 🧊 (cgroup freezer: RAM kept, zero CPU — 'grave developer' thaws)"
}

thaw_agents() {
  [[ -f "$TORPOR_CG/cgroup.freeze" ]] || return 0
  [[ "$(cat "$TORPOR_CG/cgroup.freeze")" == 1 ]] || return 0
  echo 0 | sudo tee "$TORPOR_CG/cgroup.freeze" >/dev/null
  ok "thawed agent sessions"
}

stop_dev() { # stop_dev [kill]  — kill: also destroy tmux sessions (max free RAM)
  local kill_sessions="${1:-}"
  need_root_helper
  say "Stopping developer services..."
  local s
  for s in "${DEV_SERVICES[@]}"; do sudo systemctl stop "$s" 2>/dev/null || true; ok "stopped $s"; done
  while read -r s; do [[ -n "$s" ]] && { sudo systemctl stop "$s" 2>/dev/null || true; ok "stopped $s"; }; done < <(workspace_services)
  if [[ "$kill_sessions" == kill ]]; then
    if tmuxa list-sessions >/dev/null 2>&1; then
      tmuxa kill-server 2>/dev/null || true
      ok "killed agent tmux sessions ☠️"
    fi
  else
    freeze_agents
  fi
  if dkctl is-active --quiet docker; then
    local stack idx
    for (( idx=${#DEV_STACKS[@]}-1; idx>=0; idx-- )); do
      stack="${DEV_STACKS[$idx]}"
      compose "$stack" stop 2>/dev/null || true
      ok "stopped stack $stack"
    done
    # stop any remaining containers so docker can shut down cleanly
    local rest; rest=$(dk ps -q)
    [[ -n "$rest" ]] && dk stop $rest >/dev/null
    dkctl stop docker.service; dkctl stop docker.socket 2>/dev/null || true
    ok "stopped docker"
  fi
  log "developer mode: stopped"
}

cmd_gaming() { # cmd_gaming [--kill] [--for <timespan>]
  local tier=pause duration=""
  while (($#)); do
    case "$1" in
      --kill) tier=kill ;;
      --for)  shift; duration="${1:?usage: grave gaming [--kill] [--for <duration>]}" ;;
      *)      say "usage: grave gaming [--kill] [--for <duration>]"; exit 1 ;;
    esac
    shift
  done
  [[ -z "$duration" ]] || systemd-analyze timespan "$duration" >/dev/null 2>&1 \
    || { bad "invalid --for duration '$duration' (examples: 30m, 2h, 1h30m)"; exit 1; }
  cancel_auto_thaw
  [[ -z "$duration" ]] || schedule_auto_thaw "$duration"
  local before after
  before=$(mem_available_mib)
  if [[ "$tier" == kill ]]; then stop_dev kill; else stop_dev; fi
  after=$(mem_available_mib)
  say ""
  if [[ "$tier" == kill ]]; then
    say "${BLD}🎮 Gaming mode (full kill).${RST} Freed ~$(( after - before )) MiB RAM. Agent sessions are gone."
  else
    say "${BLD}🎮 Gaming mode (torpor).${RST} Freed ~$(( after - before )) MiB RAM."
    say "Agent sessions are frozen in place — 'grave developer' thaws them."
  fi
  say "Remote access (Tailscale + SSH) is untouched."
  log "gaming mode: active ($tier, freed $(( after - before )) MiB)"
}

cmd_developer() {
  # Stopping only the timer is safe when this command is itself the transient
  # service fired by that timer; stopping the service would kill the restore.
  cancel_auto_thaw
  thaw_agents
  start_dev
  say ""
  say "${BLD}💻 Developer mode.${RST} All services up. 'grave status' for details."
  log "developer mode: active"
}

# ---------------------------------------------------------------- agents ----
cmd_agents() {
  local sub="${1:-list}"; shift || true
  case "$sub" in
    list)
      tmuxa list-sessions 2>/dev/null || say "No agent sessions. Start one: grave agents new <name> [dir]" ;;
    new)
      local name="${1:?usage: grave agents new <name> [dir]}"
      # The name is interpolated into a path and into the pipe-pane command tmux
      # runs via /bin/sh, so restrict it to a safe charset (traversal + injection).
      [[ "$name" =~ ^[A-Za-z0-9_-]+$ ]] || { bad "session name must be letters, digits, '-' or '_'"; exit 1; }
      local dir="${2:-$GRAVE_ROOT/repos}"
      tmuxa -f "$TMUX_CONF" new-session -d -s "$name" -c "$dir"
      mkdir -p "$GRAVE_ROOT/agents/$name"
      # Record the working dir so `agents resume` (and the dashboard's ▶
      # button) can bring a dead session back where it lived (#110).
      jq -n --arg dir "$dir" --arg created "$(date -u +%FT%TZ)" \
        '{dir:$dir, created:$created}' >"$GRAVE_ROOT/agents/$name/meta.json" 2>/dev/null || true
      # Resolve the dated log path in bash: the old deferred date-in-tmux form
      # double-escaped the percents and logged a literal filename, never a date.
      local logfile="$GRAVE_ROOT/agents/$name/session-$(date +%Y%m%d).log"
      tmuxa pipe-pane -t "$name" -o "cat >> '$logfile'" 2>/dev/null || true
      ok "session '$name' created in $dir (attach: grave agents attach $name)" ;;
    attach)
      exec tmux -L "$TMUX_SOCKET" attach -t "${1:?usage: grave agents attach <name>}" ;;
    kill)
      tmuxa kill-session -t "${1:?usage: grave agents kill <name>}"; ok "killed ${1}" ;;
    history)
      # Dead sessions leave their pipe-pane logs behind (#110): list every
      # session dir that has logs, live or not. agents/t3code is T3 server
      # state, not a tmux session dir.
      local d name logs last state
      printf '%-24s %-6s %-18s %s\n' "SESSION" "STATE" "LAST ACTIVITY" "LOGS"
      for d in "$GRAVE_ROOT"/agents/*/; do
        name=$(basename "$d"); [[ "$name" == t3code ]] && continue
        logs=$(ls -1 "$d" 2>/dev/null | grep -c '^session-[0-9]*\.log$') || true
        (( logs > 0 )) || continue
        last=$(date -d "@$(stat -c %Y "$d"session-*.log | sort -n | tail -1)" '+%F %H:%M')
        state=dead; tmuxa has-session -t "=$name" 2>/dev/null && state=live
        printf '%-24s %-6s %-18s %s\n' "$name" "$state" "$last" "$logs"
      done ;;
    resume)
      local name="${1:?usage: grave agents resume <name>}"
      [[ "$name" =~ ^[A-Za-z0-9_-]+$ ]] || { bad "session name must be letters, digits, '-' or '_'"; exit 1; }
      if tmuxa has-session -t "=$name" 2>/dev/null; then
        ok "session '$name' is already live (attach: grave agents attach $name)"; return
      fi
      # Back to the dir it lived in; sessions predating meta.json fall back to
      # the default. The old logs stay put — the new day's log appends beside them.
      local dir
      dir=$(jq -r '.dir // empty' "$GRAVE_ROOT/agents/$name/meta.json" 2>/dev/null) || dir=""
      [[ -d "$dir" ]] || dir="$GRAVE_ROOT/repos"
      cmd_agents new "$name" "$dir" ;;
    *) say "usage: grave agents [list|new|attach|kill|history|resume]"; exit 1 ;;
  esac
}

# ---------------------------------------------------------------- docker ----
cmd_docker() {
  local sub="${1:-ps}"; shift || true
  case "$sub" in
    ps)    dk ps -a --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}' ;;
    up)    compose "${1:?stack name}" up -d ;;
    down)  compose "${1:?stack name}" down ;;
    logs)  dk logs --tail 100 -f "${1:?container name}" ;;
    stacks) ls -1 "$GRAVE_ROOT/docker" ;;
    disk)  dk system df ;;
    *) say "usage: grave docker [ps|up <stack>|down <stack>|logs <container>|stacks|disk]"; exit 1 ;;
  esac
}

# --------------------------------------------------------------- preview ----
# Expose a running dev server to the tailnet over HTTPS at the ROOT of its own
# port — NOT behind a path. A path prefix (/preview) breaks any framework that
# assumes it lives at "/" : Vite/Next HMR websockets, /@vite, /_next, absolute
# asset URLs all 404. Serving at the port root means the dev server works
# unmodified, no per-project base-path config. The server stays bound to
# 127.0.0.1; Tailscale terminates TLS and proxies over the tailnet ONLY (this
# is `serve`, not `funnel` — nothing is exposed to the public internet).
# Ports are confined to PREVIEW_RANGE so a preview can never shadow a platform
# service (4711-4713) or anything outside the sandbox.
tailnet_host() { local h; h=$(tailscale status --json 2>/dev/null | sed -n 's/.*"DNSName": *"\([^"]*\)\.".*/\1/p'); printf '%s\n' "${h%%$'\n'*}"; }

preview_reserved() { # preview_reserved <port>  — a platform service sits on it
  local p="$1" r
  for r in ${PREVIEW_RESERVED:-}; do [[ "$p" == "$r" ]] && return 0; done
  return 1
}

preview_in_range() { # preview_in_range <port>  — valid, non-reserved preview port
  local p="$1" lo="${PREVIEW_RANGE%-*}" hi="${PREVIEW_RANGE#*-}"
  [[ "$p" =~ ^[0-9]+$ ]] && (( p >= lo && p <= hi )) && ! preview_reserved "$p"
}

port_listening() { # port_listening <port>  — something bound to it right now?
  ss -tlnH 2>/dev/null | awk '{print $4}' | grep -qE "[:.]$1\$"
}

listening_previews() { # previewable ports with a live listener (one per line)
  local p
  ss -tlnH 2>/dev/null | awk '{print $4}' | sed -n 's/.*[:.]\([0-9]\{1,\}\)$/\1/p' | sort -un |
    while read -r p; do preview_in_range "$p" && echo "$p"; done
}

preview_start() { # preview_start <port>
  local port="$1" host
  preview_reserved "$port" && { bad "port $port belongs to a platform service — refusing to expose it"; exit 1; }
  preview_in_range "$port" || { bad "port $port is outside the preview range $PREVIEW_RANGE"; exit 1; }
  host=$(tailnet_host)
  [[ -n "$host" ]] || { bad "can't read the tailnet name — is tailscale up?"; exit 1; }
  if ! port_listening "$port"; then
    say "  ${YLW}nothing is listening on 127.0.0.1:$port yet — start your dev server first (this maps it anyway).${RST}"
  fi
  tailscale serve --bg --https="$port" "http://127.0.0.1:$port" >/dev/null
  log "preview: on $port"
  ok "https://$host:$port  →  127.0.0.1:$port  (tailnet only — 'grave preview off $port' to stop)"
}

preview_stop() { # preview_stop <port>
  local port="$1"
  preview_in_range "$port" || { bad "port $port is outside the preview range $PREVIEW_RANGE"; exit 1; }
  tailscale serve --https="$port" off >/dev/null 2>&1 || true
  log "preview: off $port"
  ok "preview on $port stopped"
}

cmd_preview() { # grave preview [<port>|off <port>|list]
  local sub="${1:-}"; shift || true
  case "$sub" in
    ""|auto)
      # No port: expose the single dev server listening in range. If several
      # are up we can't guess — list them and ask for an explicit port.
      local ports; mapfile -t ports < <(listening_previews)
      case "${#ports[@]}" in
        0) say "No dev server is listening in $PREVIEW_RANGE. Start one, then:"
           say "  grave preview <port>"; exit 1 ;;
        1) preview_start "${ports[0]}" ;;
        *) say "Several dev servers are listening — name the port:"
           local p; for p in "${ports[@]}"; do say "  grave preview $p"; done; exit 1 ;;
      esac ;;
    off|stop) preview_stop "${1:?usage: grave preview off <port>}" ;;
    list|status|ls)
      local host line port any=0; host=$(tailnet_host)
      while IFS= read -r line; do
        port=$(sed -n 's#^https://[^ :]*:\([0-9]\{1,\}\).*#\1#p' <<<"$line")
        [[ -n "$port" ]] && preview_in_range "$port" && { say "  https://$host:$port  →  127.0.0.1:$port"; any=1; }
      done < <(tailscale serve status 2>/dev/null)
      (( any )) || say "  (no previews active)" ;;
    *)
      if [[ "$sub" =~ ^[0-9]+$ ]]; then preview_start "$sub"  # start (validates range/reserved)
      else say "usage: grave preview [<port>|off <port>|list]"; exit 1; fi ;;
  esac
}

# ---------------------------------------------------------------- update ----
cmd_update() {
  need_root_helper
  if command -v snapper >/dev/null; then
    say "Snapshotting before update..."
    sudo snapper -c root create --description "grave-pre-update" --cleanup-algorithm number || true
  fi
  if [[ "${CHECK_IMMUTABLE_ROOT:-0}" == 1 ]]; then
    # Immutable rootfs (e.g. stock SteamOS): never pacman into read-only /usr —
    # it won't survive an OS update. The durable toolchain updates via Homebrew
    # under $HOME; the base OS updates through its own image updater. See
    # docs/STEAMOS.md.
    if command -v brew >/dev/null; then
      say "Updating Homebrew toolchain..."
      brew update >/dev/null 2>&1 && brew upgrade 2>&1 | tail -1 || say "${YLW}brew upgrade had issues (non-fatal)${RST}"
    fi
    say "${YLW}base OS is image-based — update it with the system updater, not grave${RST}"
  else
    say "Updating system packages..."
    case "$(pkg_mgr)" in
      pacman) sudo pacman -Syu --noconfirm
              if command -v paru >/dev/null; then paru -Sua --noconfirm || say "${YLW}AUR update had issues (non-fatal)${RST}"; fi ;;
      apt)    sudo apt-get update && sudo apt-get -y upgrade ;;
      dnf)    sudo dnf -y upgrade ;;
      *)      say "${YLW}no known package manager — skipping system update${RST}" ;;
    esac
    if ((${#NPM_GLOBAL_TOOLS[@]})); then
      say "Updating npm-global tools..."
      sudo npm update -g "${NPM_GLOBAL_TOOLS[@]}" 2>&1 | tail -1 || true
    fi
  fi
  say "Checking T3 Code..."
  cmd_t3 update
  if dkctl is-active --quiet docker; then
    say "Pulling docker images..."
    local stack; for stack in "${DEV_STACKS[@]}"; do compose "$stack" pull -q || true; done
  fi
  say "Agent CLIs (claude/codex) self-update on launch."
  log "update: completed"
  ok "update complete — reboot only if the kernel changed"
}

# -------------------------------------------------------------- bootmode ----
cmd_bootmode() { # what the box boots into: developer (dev services up) or gaming
  case "${1:-}" in
    "")
      # Capture then take the first line in bash — piping the streaming
      # workspace_services into `head -1` closes the pipe early, SIGPIPEs the
      # producer, and under `set -o pipefail` aborts `grave bootmode` (exit 141).
      local first_workspace; first_workspace=$(workspace_services); first_workspace=${first_workspace%%$'\n'*}
      if systemctl is-enabled --quiet t3code 2>/dev/null || { [[ -n "$first_workspace" ]] && systemctl is-enabled --quiet "$first_workspace"; }; then
        say "boot mode: developer (dev services start at boot)"
      else
        say "boot mode: gaming (dev services stay down until 'grave developer')"
      fi ;;
    developer|dev)
      need_root_helper
      sudo systemctl enable t3code >/dev/null 2>&1 || true
      while read -r s; do [[ -n "$s" ]] && sudo systemctl enable "$s" >/dev/null 2>&1 || true; done < <(workspace_services)
      dkctl enable docker >/dev/null 2>&1 || true   # rootless: per-user unit
      ok "boot mode: developer — dev services start automatically after reboot" ;;
    gaming|game)
      need_root_helper
      sudo systemctl disable t3code >/dev/null 2>&1 || true
      while read -r s; do [[ -n "$s" ]] && sudo systemctl disable "$s" >/dev/null 2>&1 || true; done < <(workspace_services)
      dkctl disable docker docker.socket >/dev/null 2>&1 || true
      ok "boot mode: gaming — after reboot only ALWAYS_ON runs; 'grave developer' wakes the rest" ;;
    *) say "usage: grave bootmode [developer|gaming]"; exit 1 ;;
  esac
}

# ------------------------------------------------------------- gamewatch ----
# Game-mode auto-throttle toggle. The gravedecay-gamewatch.service loop watches
# for a running game and flips grave gaming/developer; this just flips the flag
# file it reads each poll (no sudo — the file lives under $GRAVE_ROOT).
cmd_gamewatch() {
  local flag="$GRAVE_ROOT/config/gamewatch.on" state="$GRAVE_ROOT/logs/gamewatch.state"
  case "${1:-status}" in
    on)  systemctl cat gravedecay-gamewatch.service >/dev/null 2>&1 \
           || { bad "gravedecay-gamewatch.service not installed — re-run raise.sh first"; exit 1; }
         mkdir -p "$GRAVE_ROOT/config"; printf 'on\n' >"$GAMEWATCH_PREFERENCE"; : > "$flag"; rm -f "$state"
         ok "auto-throttle ON — launching a game freezes agents; 'grave gamewatch off' to stop" ;;
    off) mkdir -p "$GRAVE_ROOT/config"; printf 'off\n' >"$GAMEWATCH_PREFERENCE"; rm -f "$flag" "$state"
         ok "auto-throttle OFF (persistent; games no longer flip modes)" ;;
    status)
      [[ -e "$flag" ]] && say "auto-throttle: ${GRN}on${RST}" || say "auto-throttle: ${YLW}off${RST}"
      [[ -r "$GAMEWATCH_PREFERENCE" ]] && say "  saved preference: $(tr -d '[:space:]' <"$GAMEWATCH_PREFERENCE")"
      if systemctl is-active --quiet gravedecay-gamewatch; then say "  watcher service: running"
      else say "  watcher service: ${YLW}stopped${RST} (re-run raise.sh)"; fi
      [[ -r "$GRAVE_ROOT/logs/gamewatch.state" ]] && say "  last seen: $(cat "$GRAVE_ROOT/logs/gamewatch.state")" ;;
    *) say "usage: grave gamewatch [on|off|status]"; exit 1 ;;
  esac
}

# ------------------------------------------------------------ keepalive ----
# "Always alive" toggle. The gravedecay-keepalive.service loop pings online
# tailnet peers every couple of seconds so a remote device on a DERP relay keeps
# its path warm and its T3/dashboard websocket doesn't idle-drop. This just
# flips the flag file the loop reads each poll (no sudo — it lives under
# $GRAVE_ROOT).
cmd_keepalive() {
  local flag="$GRAVE_ROOT/config/keepalive.on"
  case "${1:-status}" in
    on)  systemctl cat gravedecay-keepalive.service >/dev/null 2>&1 \
           || { bad "gravedecay-keepalive.service not installed on this host — re-raise to install it"; exit 1; }
         mkdir -p "$GRAVE_ROOT/config"; : > "$flag"
         ok "always-alive ON — warming tailnet relay paths; 'grave keepalive off' to stop" ;;
    off) rm -f "$flag"; ok "always-alive OFF (tailnet paths no longer warmed)" ;;
    status)
      [[ -e "$flag" ]] && say "always-alive: ${GRN}on${RST}" || say "always-alive: ${YLW}off${RST}"
      if systemctl is-active --quiet gravedecay-keepalive; then say "  keepalive service: running"
      else say "  keepalive service: ${YLW}stopped${RST} (re-raise to install)"; fi ;;
    *) say "usage: grave keepalive [on|off|status]"; exit 1 ;;
  esac
}

# ---------------------------------------------------------------- notify ----
# Push a message to the human (docs/NOTIFICATIONS.md) over two channels:
#   ntfy     — $GRAVE_ROOT/config/secrets/notify.env (600, git-ignored):
#                NTFY_URL=https://ntfy.sh/<random-topic>
#                NTFY_TOKEN=tk_...          # optional bearer token
#   Web Push — PWA devices enrolled from ⚙️ settings; the dashboard holds the
#              VAPID key + subscriptions and does the crypto, we just POST the
#              message to its loopback /api/push-send.
# Event sources (tmux hooks, OnFailure= units, doctor) call
# `grave notify --event <name>`, which is a silent no-op unless a channel is
# configured AND the event class is listed in NOTIFY_EVENTS — so the hooks ship
# enabled everywhere without spamming an unconfigured box.
ntfy_ready() {
  [[ -r "$NOTIFY_ENV" ]] || return 1
  # shellcheck disable=SC1090
  ( source "$NOTIFY_ENV"; [[ "${NTFY_URL:-}" =~ ^https?:// ]] )
}

push_ready() { # at least one PWA device is enrolled for Web Push
  [[ -s "$PUSH_SUBS" ]] && jq -e '.subscriptions | length > 0' "$PUSH_SUBS" >/dev/null 2>&1
}

notify_configured() { ntfy_ready || push_ready; }

ntfy_send() { # ntfy_send <title> <body> <priority>
  local title="$1" body="$2" priority="$3"
  # shellcheck disable=SC1090
  source "$NOTIFY_ENV"
  [[ "${NTFY_URL:-}" =~ ^https?:// ]] || return 1
  # Headers are a protocol boundary: a newline in an interpolated value (a tmux
  # session name reaches here) becomes header injection. Strip CR/LF and pin
  # the priority to ntfy's vocabulary. The body travels as --data-raw, never
  # -d/--data-binary, whose @ prefix would read local files into the request.
  title=${title//[$'\r\n']/ }
  [[ "$priority" =~ ^[a-z1-5]+$ ]] || priority=default
  local args=(-sf -m 10 -o /dev/null -H "Title: $title" -H "Priority: $priority")
  [[ -n "${NTFY_TOKEN:-}" ]] && args+=(-H "Authorization: Bearer ${NTFY_TOKEN//[$'\r\n']/}")
  curl "${args[@]}" --data-raw "$body" "$NTFY_URL"
}

PUSH_ERROR=""
push_send() { # push_send <title> <body> <priority> <link> <event>
  # jq builds the JSON so a hostile session name can't break out of the
  # payload; the dashboard validates the link (on-origin paths only). Keep the
  # response: its output carries the push service's rejection reason (#97 —
  # discarding it turned Apple's 'BadJwtToken' into a bare 'delivery failed').
  local resp
  resp=$(jq -n --arg t "$1" --arg b "$2" --arg p "$3" --arg u "$4" --arg e "$5" \
      '{title:$t, body:$b, priority:$p, url:$u, tag:(if $e=="" then "manual" else $e end)}' \
    | curl -s -m 15 -X POST -H 'Content-Type: application/json' \
        --data-binary @- "http://127.0.0.1:${DASH_PORT:-4712}/api/push-send") || { PUSH_ERROR="dashboard unreachable"; return 1; }
  jq -e .ok <<<"$resp" >/dev/null 2>&1 && return 0
  PUSH_ERROR=$(jq -r '.output // "push failed"' <<<"$resp" 2>/dev/null)
  return 1
}

notify_record() { # notify_record <title> <body> <link> <event> <delivered> — inbox line (#119)
  # Pushes are ephemeral on every channel (dismiss and it's gone; iOS truncates
  # long bodies); this file is the durable copy the dashboard's 🔔 Inbox
  # renders. jq builds the JSON so hostile titles/session names can't break the
  # encoding; 0600 because bodies carry private detail; best-effort throughout —
  # a full disk must never break delivery itself.
  local inbox="$GRAVE_ROOT/logs/notifications.jsonl"
  {
    mkdir -p "$GRAVE_ROOT/logs"
    # size-capped: keep the newest ~400 entries once the file passes 256 KiB
    if [[ -f "$inbox" ]] && (( $(stat -c %s "$inbox") > 262144 )); then
      tail -n 400 "$inbox" >"$inbox.tmp" && mv "$inbox.tmp" "$inbox"
    fi
    [[ -f "$inbox" ]] || : >"$inbox"
    chmod 600 "$inbox"
    jq -nc --arg t "$1" --arg b "$2" --arg l "$3" --arg e "$4" --argjson d "$5" \
      '{ts:(now|floor), event:(if $e=="" then "manual" else $e end),
        title:$t, body:$b, link:$l, delivered:$d}' >>"$inbox"
  } 2>/dev/null || true
}

notify_send() { # notify_send <title> <body> <priority> <link> <event> — ok if ANY channel delivered
  local sent=0
  if ntfy_ready; then ntfy_send "$1" "$2" "$3" && sent=1; fi
  if push_ready; then push_send "$1" "$2" "$3" "$4" "$5" && sent=1; fi
  notify_record "$1" "$2" "$4" "$5" "$([[ $sent == 1 ]] && echo true || echo false)"
  (( sent ))
}

notify_reachable() {
  # Doctor probe without publishing: ntfy's poll endpoint returns the topic's
  # cached messages and exercises auth, so a doctor run never pages the phone.
  # shellcheck disable=SC1090
  source "$NOTIFY_ENV"
  [[ "${NTFY_URL:-}" =~ ^https?:// ]] || return 1
  local args=(-sf -m 10 -o /dev/null)
  [[ -n "${NTFY_TOKEN:-}" ]] && args+=(-H "Authorization: Bearer ${NTFY_TOKEN//[$'\r\n']/}")
  curl "${args[@]}" "$NTFY_URL/json?poll=1"
}

claude_notify_hook_present() {
  local settings="$HOME/.claude/settings.json" cmd="$AGENT_NOTIFY claude"
  [[ -r "$settings" ]] || return 1
  jq -e --arg cmd "$cmd" '
    def hascmd($name): any(.hooks[$name][]?; any(.hooks[]?; .command == $cmd));
    hascmd("Stop") and hascmd("Notification")
  ' "$settings"
}

codex_notify_hook_present() {
  local conf="$HOME/.codex/config.toml"
  [[ -r "$conf" ]] || return 1
  grep -Eq '^[[:space:]]*notify[[:space:]]*=.*grave-agent-notify.*codex' "$conf"
}

cmd_notify() { # grave notify [--event <name>] [--priority <p>] [--link </path>] <title> [body...]
  local event="" priority=default link=""
  while (($#)); do
    case "$1" in
      --event)    event="${2:?event name}"; shift 2 ;;
      --priority) priority="${2:?priority}"; shift 2 ;;
      --link)     link="${2:?link}"; shift 2 ;;   # on-origin deep link for the push tap
      --) shift; break ;;
      -*) say "usage: grave notify [--event <name>] [--priority min|low|default|high|urgent] [--link </path>] <title> [body]"; exit 1 ;;
      *) break ;;
    esac
  done
  local title="${1:-}"; shift || true
  local body="$*"
  if [[ -n "$event" ]]; then
    # Hook-driven path: tmux hooks and OnFailure units fire on EVERY box,
    # configured or not, and must never fail their caller — drop quietly when
    # no channel is configured or the event class is muted in NOTIFY_EVENTS.
    notify_configured || exit 0
    local e enabled=0
    for e in $NOTIFY_EVENTS; do [[ "$e" == "$event" ]] && enabled=1; done
    (( enabled )) || exit 0
    [[ -n "$title" ]] || exit 0
    notify_send "$title" "${body:-$event}" "$priority" "$link" "$event" || { log "notify: $event delivery failed${PUSH_ERROR:+ — $PUSH_ERROR}"; exit 0; }
    log "notify: $event — $title"
    exit 0
  fi
  [[ -n "$title" ]] || { say "usage: grave notify <title> [body]"; exit 1; }
  notify_configured || {
    bad "notifications are not configured"
    say "  Web Push (recommended, no account): dashboard ⚙️ settings → Notifications → 🔔 enable"
    say "  ntfy (optional relay): create $NOTIFY_ENV (chmod 600) with:"
    say "    NTFY_URL=https://ntfy.sh/<your-random-topic>"
    say "    NTFY_TOKEN=tk_...   # optional (authed/self-hosted servers)"
    say "  Full guide: docs/NOTIFICATIONS.md"
    exit 1
  }
  notify_send "$title" "$body" "$priority" "$link" "" || { bad "delivery failed on every channel${PUSH_ERROR:+ — $PUSH_ERROR}"; exit 1; }
  ok "notification sent"
  log "notify: manual — $title"
}

# ---------------------------------------------------------------- digest ----
# One page at ~08:00 (gravedecay-digest.timer) answering "what did the box do
# overnight?": agent sessions, spend, the doctor verdict, backup freshness.
# Delivery goes through `grave notify --event digest`, so it inherits the usual
# gating — a silent no-op when no channel is configured or the class is muted
# in ⚙️ settings — and the timer can safely fire on every box.
cmd_digest() { # grave digest [--print]  (--print: compose only, never page)
  local print_only=0
  [[ "${1:-}" == "--print" ]] && print_only=1

  # Agents: tmux sessions live right now, plus per-provider session counts from
  # the CLIs' own state dirs. T3 shells out to the same claude/codex binaries
  # with default state paths, so counting transcripts covers T3, tmux, and bare
  # CLI sessions alike — tmux alone would read "0" every morning on a T3-first
  # box. Claude: one .jsonl per session (subagent transcripts excluded);
  # Codex: one rollout-*.jsonl per session.
  local live_names live=0 claude_24h codex_24h
  live_names=$(tmuxa list-sessions -F '#S' 2>/dev/null | paste -sd, -) || live_names=""
  [[ -n "$live_names" ]] && live=$(awk -F, '{print NF}' <<<"$live_names")
  claude_24h=$(find "$HOME/.claude/projects" -name '*.jsonl' -not -path '*/subagents/*' \
               -mmin -1440 2>/dev/null | wc -l)
  codex_24h=$(find "$HOME/.codex/sessions" -name 'rollout-*.jsonl' -mmin -1440 2>/dev/null | wc -l)
  local agents_line="agents: $live tmux live${live_names:+ ($live_names)} · 24h sessions: $claude_24h Claude, $codex_24h Codex"

  # Spend: the dashboard already parses the Claude/Codex transcripts — ask it
  # on loopback instead of duplicating the parsers in bash. Its absence (gaming
  # mode, stopped) is itself morning news, so say so rather than omit the line.
  local usage spend_line="spend: dashboard stopped — no numbers this morning"
  usage=$(curl -sf -m 10 "http://127.0.0.1:${DASH_PORT:-4712}/api/state" 2>/dev/null \
          | jq -c '.usage // empty' 2>/dev/null) || usage=""
  if [[ -n "$usage" ]]; then
    spend_line=$(jq -r '
      def k: (. // 0) | if . >= 1000000 then "\((. / 100000 | round) / 10)M"
             elif . >= 1000 then "\((. / 1000) | round)k" else tostring end;
      "spend: Claude $\(((.claude.today.cost // 0) * 100 | round) / 100)"
      + " (\(.claude.today.msgs // 0) msgs)"
      + " · Codex \(((.codex.today.in // 0) + (.codex.today.cached // 0) + (.codex.today.out // 0)) | k) tok"
      + " (\(.codex.today.sessions // 0) sessions)"' <<<"$usage" 2>/dev/null) \
      || spend_line="spend: unavailable (unexpected /api/state shape)"
  fi

  # Doctor: the full contract run, with its own page suppressed — the digest
  # IS the morning page, and two notifications about one failure teach the
  # human to mute both.
  local doctor_line doctor_out doctor_rc
  set +e
  doctor_out=$("$0" doctor --no-page 2>/dev/null)
  doctor_rc=$?
  set -e
  if (( doctor_rc == 0 )); then
    doctor_line="doctor: ✓ all checks passed"
  else
    local fails; fails=$(grep -oE '[0-9]+ check\(s\) failed' <<<"$doctor_out" | tail -1)
    doctor_line="doctor: ✗ ${fails:-failing} — run: grave doctor"
  fi

  local backup_line="backup: none verified yet — run: grave backup"
  if [[ -f "$BACKUP_DIR/.last-verified" ]]; then
    local age_h=$(( ($(date +%s) - $(stat -c %Y "$BACKUP_DIR/.last-verified")) / 3600 ))
    backup_line="backup: ✓ verified ${age_h}h ago"
  fi

  local body title
  body=$(printf '%s\n' "🤖 $agents_line" "🧾 $spend_line" "🩺 $doctor_line" "🪦 $backup_line")
  # $HOSTNAME (bash builtin) — the hostname binary is an optional package on
  # Arch-family hosts and the digest must not depend on it.
  title="🌄 ${HOSTNAME:-gravedecay}: $live agent(s) live, doctor $([[ $doctor_rc == 0 ]] && echo ✓ || echo ✗)"
  say "$body"
  (( print_only )) && return 0
  cmd_notify --event digest --link "/grave/" "$title" "$body"
}

# --------------------------------------------------------------- upgrade ----
upgrade_repo() {
  local repo="${REPO_DIR:-$GRAVE_ROOT/repos/gravedecay}"
  [[ -d "$repo/.git" ]] || { bad "gravedecay checkout not found at $repo (set REPO_DIR in grave.conf)"; exit 1; }
  printf '%s\n' "$repo"
}

fetch_upgrade_refs() {
  local repo="$1"
  git -C "$repo" fetch --tags --prune -q origin
  git -C "$repo" remote set-head origin -a >/dev/null 2>&1 || true
}

cmd_releases() { # grave releases [--json] — list selectable stable releases
  local format="${1:-}" repo current checkout
  [[ -z "$format" || "$format" == "--json" ]] || { say "usage: grave releases [--json]"; exit 1; }
  repo=$(upgrade_repo)
  fetch_upgrade_refs "$repo"
  current=$(git -C "$repo" describe --tags --exact-match HEAD 2>/dev/null || true)
  checkout="${current:-$(git -C "$repo" branch --show-current)}"
  [[ -n "$checkout" ]] || checkout=$(git -C "$repo" rev-parse --short HEAD)
  local tags
  tags=$(git -C "$repo" tag -l 'v[0-9]*.[0-9]*.[0-9]*' --sort=-v:refname \
    | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -20 || true)
  if [[ "$format" == "--json" ]]; then
    jq -n --arg current "$current" --arg checkout "$checkout" \
      --argjson releases "$(printf '%s\n' "$tags" | jq -Rsc 'split("\n")|map(select(length>0))')" \
      '{current:$current,checkout:$checkout,releases:$releases}'
  else
    say "gravedecay checkout: $checkout"
    [[ -n "$tags" ]] && printf '  %s\n' $tags || say "  no stable releases found"
  fi
}

cmd_upgrade() { # grave upgrade [--edge|--release|--tag vX.Y.Z]
  local channel="${UPGRADE_CHANNEL:-release}"
  local repo tag=""
  repo=$(upgrade_repo)
  while (($#)); do
    case "$1" in
      --edge) channel=edge; shift ;;
      --release) channel=release; shift ;;
      --tag)
        [[ $# -ge 2 && "$2" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]] || {
          say "usage: grave upgrade [--edge|--release|--tag vX.Y.Z]"; exit 1;
        }
        channel=tag; tag="$2"; shift 2 ;;
      *) say "usage: grave upgrade [--edge|--release|--tag vX.Y.Z]"; exit 1 ;;
    esac
  done
  if [[ -n "$(git -C "$repo" status --porcelain)" ]]; then
    bad "checkout at $repo has local changes — commit or stash them first"
    exit 1
  fi
  say "Fetching updates (${channel} channel)..."
  fetch_upgrade_refs "$repo"
  local target=""
  if [[ "$channel" == tag ]]; then
    git -C "$repo" rev-parse -q --verify "refs/tags/$tag^{commit}" >/dev/null || {
      bad "release $tag does not exist in the configured repository"
      exit 1
    }
    target="$tag"
  elif [[ "$channel" == release ]]; then
    target=$(git -C "$repo" tag -l 'v*' --sort=-v:refname | head -1)
    if [[ -z "$target" ]]; then
      say "${YLW}no release tags found — following main instead${RST}"
      channel=edge
    fi
  fi
  if [[ "$channel" == edge ]]; then
    local branch
    branch=$(git -C "$repo" symbolic-ref -q --short refs/remotes/origin/HEAD || echo origin/master)
    branch=${branch#origin/}
    git -C "$repo" checkout -q "$branch"
    git -C "$repo" pull -q --ff-only origin "$branch"
    target="$branch"
  else
    git -C "$repo" checkout -q --detach "$target"
  fi
  ok "checked out $target ($(git -C "$repo" rev-parse --short HEAD))"
  say "Re-running the ritual (idempotent)..."
  bash "$repo/raise.sh"
  log "upgrade: $target"
}

# ------------------------------------------------------------------ logs ----
cmd_logs() {
  local target="${1:-grave}"
  case "$target" in
    t3|t3code)  sudo journalctl -u t3code -n 100 -f ;;
    dash|gravedecay) sudo journalctl -u gravedecay -n 100 -f ;;
    term)       sudo journalctl -u gravedecay-term -n 100 -f ;;
    ssh|sshd)   sudo journalctl -u sshd -n 100 -f ;;
    tailscale)  sudo journalctl -u tailscaled -n 100 -f ;;
    system)     sudo journalctl -p warning -n 100 -f ;;
    grave)      tail -n 50 -f "$LOG_FILE" ;;
    agent)      tail -n 100 -f "$GRAVE_ROOT"/agents/"${2:?agent name}"/session-*.log ;;
    workspace)  sudo journalctl -u "gravedecay-t3@${2:?workspace}" -u "gravedecay-term@${2}" -u "gravedecay-dashboard@${2}" -n 150 -f ;;
    *)          dk logs --tail 100 -f "$target" 2>/dev/null || \
                sudo journalctl -u "$target" -n 100 -f ;;
  esac
}

# ---------------------------------------------------------------- doctor ----
check() { # check <description> <command...>
  if "${@:2}" >/dev/null 2>&1; then ok "$1"; else bad "$1"; FAILURES=$((FAILURES+1)); fi
}
firewall_active() {
  # Not merely "a firewall is running": the appliance boundary (AGENTS.md §3) is
  # default-deny incoming (only ssh + tailscale0 allowed). A firewall that is up
  # but defaults to allow-in still violates it, so assert the default policy too.
  if command -v ufw >/dev/null; then
    local s; s=$(sudo ufw status verbose 2>/dev/null) || return 1
    grep -q "Status: active" <<<"$s" && grep -qE "Default: (deny|reject) \(incoming\)" <<<"$s"
  elif command -v firewall-cmd >/dev/null; then
    firewall-cmd --state >/dev/null 2>&1 || return 1
    local zone; zone=$(firewall-cmd --get-default-zone 2>/dev/null) || return 1
    # the default zone must not blanket-accept inbound (trusted, or target ACCEPT)
    [[ "$zone" != trusted ]] && ! firewall-cmd --info-zone="$zone" 2>/dev/null | grep -q 'target: ACCEPT'
  else return 1; fi
}
cmd_doctor() { # grave doctor [--no-page]
  # --no-page suppresses the failure notification: `grave digest` embeds the
  # doctor verdict in its own single morning page, and two pages about one
  # failing contract is how notifications get muted wholesale.
  local no_page=0
  [[ "${1:-}" == "--no-page" ]] && no_page=1
  FAILURES=0
  hdr "grave doctor"
  check "tailscaled running"            systemctl is-active --quiet tailscaled
  check "tailscale logged in"           tailscale status --peers=false
  # OpenSSH server unit is `sshd` on Arch/Fedora, `ssh` on Debian/Ubuntu.
  check "ssh server running"            bash -c "systemctl is-active --quiet sshd || systemctl is-active --quiet ssh"
  if [[ "${CHECK_FIREWALL:-1}" == 1 ]]; then
    check "firewall active"             firewall_active
  else
    say "  ${YLW}– firewall check relaxed (LAN kept open for gaming; boundary is 127.0.0.1 + tailnet)${RST}"
  fi
  check "ssh password auth disabled"    bash -c "sudo sshd -T | grep -qi 'passwordauthentication no'"
  if [[ "${CHECK_SLEEP_MASKED:-0}" == 1 ]]; then
    check "sleep targets masked"        bash -c '[[ $(systemctl is-enabled sleep.target) == masked ]]'
  fi
  if [[ "${CHECK_LID_IGNORED:-0}" == 1 ]]; then
    check "lid switch ignored"          bash -c '[[ $(busctl get-property org.freedesktop.login1 /org/freedesktop/login1 org.freedesktop.login1.Manager HandleLidSwitch) == *ignore* ]]'
  fi
  if [[ "${CHECK_DOCKER_SUBVOL:-0}" == 1 ]]; then
    check "/var/lib/docker on own subvol" bash -c 'findmnt -n /var/lib/docker | grep -q subvol'
  fi
  if [[ "${CHECK_SNAPPER:-0}" == 1 ]]; then
    check "snapper config for GRAVE_ROOT" sudo snapper -c "${SNAPPER_CONFIG:-srv}" list
  fi
  if [[ "${CHECK_IMMUTABLE_ROOT:-0}" == 1 ]]; then
    # On an image-based rootfs (SteamOS) an OS update replaces /usr. Everything
    # we rely on must therefore live off the root mount, or it silently vanishes.
    check "GRAVE_ROOT off the immutable root mount" \
      bash -c "[[ \"\$(findmnt -no TARGET --target '$GRAVE_ROOT')\" != / ]]"
    check "durable toolchain under \$HOME (Homebrew)" command -v brew
    check "Docker is rootless (survives OS updates)" \
      bash -c "[[ '${DOCKER_ROOTLESS:-0}' == 1 ]]"
    # /etc drift after a SteamOS update — the self-heal boot unit drops this
    # marker when a config file it depends on went missing (see docs/STEAMOS.md).
    if [[ -f "$GRAVE_ROOT/logs/DRIFT-DETECTED" ]]; then
      bad "config drift after OS update — re-run raise.sh (see $GRAVE_ROOT/logs/selfheal.log)"
      FAILURES=$((FAILURES+1))
    fi
  fi
  # --- reboot-readiness: "active" isn't "enabled". A unit that's running now
  # but not enabled won't come back after a reboot, so surviving a reboot is
  # only real if these pass. (Doctor is the contract.)
  local u
  for u in "${ALWAYS_ON[@]}"; do
    systemctl cat "$u.service" >/dev/null 2>&1 || continue   # unit not on this host
    check "$u enabled (starts at boot)"  systemctl is-enabled --quiet "$u"
  done
  # DEV_SERVICES enablement IS the boot-mode toggle: `grave bootmode gaming`
  # deliberately disables them, so a disabled dev service is an expected state,
  # not a reboot-readiness failure. Report the mode instead of counting a failure.
  for u in "${DEV_SERVICES[@]}"; do
    systemctl cat "$u.service" >/dev/null 2>&1 || continue
    if systemctl is-enabled --quiet "$u"; then ok "$u enabled (boot mode: developer)"
    else say "  ${YLW}– $u disabled at boot (boot mode: gaming — 'grave developer' to wake)${RST}"; fi
  done
  if [[ "${DOCKER_ROOTLESS:-0}" == 1 ]]; then
    check "rootless docker enabled at boot"   systemctl --user is-enabled --quiet docker
    check "linger on (user services start without login)" \
      bash -c "loginctl show-user \"\$(id -un)\" 2>/dev/null | grep -q 'Linger=yes'"
  fi
  if [[ -r "$GAMEWATCH_PREFERENCE" ]]; then
    local gamewatch_preference
    gamewatch_preference="$(tr -d '[:space:]' <"$GAMEWATCH_PREFERENCE")"
    case "$gamewatch_preference" in
      on)  check "gamewatch preference synced (on)" test -e "$GRAVE_ROOT/config/gamewatch.on" ;;
      off) check "gamewatch preference synced (off)" test ! -e "$GRAVE_ROOT/config/gamewatch.on" ;;
      *)   bad "invalid gamewatch preference '$gamewatch_preference' (expected on or off)"
           FAILURES=$((FAILURES+1)) ;;
    esac
  else
    say "  ${YLW}– gamewatch preference not initialized — re-run raise.sh${RST}"
  fi
  if [[ -e "$GRAVE_ROOT/config/gamewatch.on" ]]; then
    if systemctl cat gravedecay-gamewatch.service >/dev/null 2>&1; then
      check "game-mode watcher running"   systemctl is-active --quiet gravedecay-gamewatch
      check "game-mode watcher enabled"   systemctl is-enabled --quiet gravedecay-gamewatch
      local detector_report detector_rc
      set +e
      detector_report="$($GRAVE_ROOT/scripts/gravedecay-gamewatch doctor 2>&1)"
      detector_rc=$?
      set -e
      case "$detector_rc" in
        0) ok "game detection signals evaluable ($detector_report)" ;;
        2) say "  ${YLW}– game detection has only the fragile process fallback ($detector_report)${RST}" ;;
        *) bad "game detection signals unusable ($detector_report)"; FAILURES=$((FAILURES+1)) ;;
      esac
    else
      bad "gamewatch on but gravedecay-gamewatch.service not installed — 'grave gamewatch off' or re-run raise.sh"
      FAILURES=$((FAILURES+1))
    fi
  fi
  if [[ -e "$GRAVE_ROOT/config/keepalive.on" ]]; then
    if systemctl cat gravedecay-keepalive.service >/dev/null 2>&1; then
      check "tailnet keepalive running"   systemctl is-active --quiet gravedecay-keepalive
      check "tailnet keepalive enabled"   systemctl is-enabled --quiet gravedecay-keepalive
    else
      bad "keepalive on but gravedecay-keepalive.service not installed — 'grave keepalive off' or re-raise"
      FAILURES=$((FAILURES+1))
    fi
  fi
  if dkctl is-active --quiet docker; then
    check "docker healthy"              dk info
    # dk is a shell function, so expand the real argv for the piped subshell
    check "no LAN-exposed containers"   bash -c "! ${_DOCKER[*]} ps --format '{{.Ports}}' | grep -E '0\.0\.0\.0|\[::\]'"
  else
    say "  ${YLW}– docker stopped (gaming mode?)${RST}"
  fi
  if systemctl is-active --quiet t3code; then
    check "t3 CLI runs"                   t3 --version
    check "t3code answering"            curl -sf -o /dev/null "http://127.0.0.1:$T3_PORT/"
  else
    say "  ${YLW}– t3code stopped (gaming mode?)${RST}"
  fi
  if systemctl is-active --quiet gravedecay; then
    check "gravedecay answering"         curl -sf -o /dev/null "http://127.0.0.1:$DASH_PORT/healthz"
    check "dashboard running installed build" bash -c \
      "test \"\$(sha256sum '$GRAVE_ROOT/scripts/gravedecay.py' | cut -d' ' -f1)\" = \"\$(curl -sf 'http://127.0.0.1:$DASH_PORT/healthz' | jq -r .build)\""
    check "dashboard self-updater installed" systemctl cat gravedecay-upgrade.service
    check "selectable release updater installed" systemctl cat 'gravedecay-upgrade@.service'
    check "dashboard PWA owns app origin" bash -c \
      "curl -sf 'http://127.0.0.1:$DASH_PORT/manifest.webmanifest' | grep -q '\"scope\": \"/\"'"
    check "dashboard offline shell ready" bash -c \
      "curl -sf -D - -o /dev/null 'http://127.0.0.1:$DASH_PORT/sw.js' | grep -qi '^Service-Worker-Allowed: /'"
  else
    say "  ${YLW}– gravedecay stopped${RST}"
  fi
  if systemctl is-active --quiet gravedecay-term; then
    check "web terminal answering"       curl -sf -o /dev/null "http://127.0.0.1:${TERM_PORT:-4713}/"
  else
    say "  ${YLW}– web terminal stopped${RST}"
  fi
  check "backups dir writable"          test -w "$BACKUP_DIR"
  # Backup freshness (#112): .last-verified is written only after every artifact
  # in a run was created AND verified, so "fresh marker" means "a restorable
  # backup exists", not "the timer fired". Gated on the timer unit so installs
  # that predate it degrade to a nudge instead of a failure.
  if systemctl cat gravedecay-backup.timer >/dev/null 2>&1; then
    check "backup timer enabled"        systemctl is-enabled --quiet gravedecay-backup.timer
    check "backup timer active"         systemctl is-active --quiet gravedecay-backup.timer
    if [[ -f "$BACKUP_DIR/.last-verified" ]]; then
      check "verified backup newer than ${BACKUP_MAX_AGE_DAYS}d" bash -c \
        "(( \$(date +%s) - \$(stat -c %Y '$BACKUP_DIR/.last-verified') < ${BACKUP_MAX_AGE_DAYS} * 86400 ))"
    else
      say "  ${YLW}– no verified backup yet — first nightly run pending (or now: grave backup)${RST}"
    fi
  else
    say "  ${YLW}– backup timer not installed — re-run raise.sh${RST}"
  fi
  # Notification inbox (#119): bodies carry private detail (session names,
  # doctor output), so the durable copy must stay owner-only.
  if [[ -f "$GRAVE_ROOT/logs/notifications.jsonl" ]]; then
    check "notification inbox is private" bash -c "[[ \$(stat -c %a '$GRAVE_ROOT/logs/notifications.jsonl') == 600 ]]"
  fi
  # Morning digest (#106): same shape as the backup timer — the schedule is the
  # invariant; whether it actually pages is the human's ⚙️ preference (digest
  # class in NOTIFY_EVENTS), which doctor deliberately does not second-guess.
  if systemctl cat gravedecay-digest.timer >/dev/null 2>&1; then
    check "digest timer enabled"        systemctl is-enabled --quiet gravedecay-digest.timer
    check "digest timer active"         systemctl is-active --quiet gravedecay-digest.timer
  else
    say "  ${YLW}– digest timer not installed — re-run raise.sh${RST}"
  fi
  # Notification invariants, each gated on its channel being opted into: a
  # dead channel silently eats every page, so reachability is an invariant,
  # not a nicety (see docs/NOTIFICATIONS.md).
  if [[ -e "$NOTIFY_ENV" ]]; then
    check "ntfy channel reachable"      notify_reachable
    check "ntfy secret is private"      bash -c "[[ \$(stat -c %a '$NOTIFY_ENV') == 600 ]]"
  fi
  if push_ready; then
    check "push subscription store is private" bash -c "[[ \$(stat -c %a '$PUSH_SUBS') == 600 ]]"
    check "push VAPID key is private"   bash -c "[[ \$(stat -c %a '$GRAVE_ROOT/config/secrets/vapid.pem') == 600 ]]"
    # The dashboard does the Web Push crypto — ask it, don't guess: 501 here
    # means python3-cryptography vanished (e.g. after an OS update).
    check "web push sender ready"       bash -c "curl -sf 'http://127.0.0.1:$DASH_PORT/api/push-key' | jq -e .ok"
  fi
  if [[ -e "$NOTIFY_ENV" ]] || push_ready; then
    check "failure notifier installed"  systemctl cat 'gravedecay-notify@.service'
    check "agent notify helper installed" test -x "$AGENT_NOTIFY"
    check "Claude notify hooks installed" claude_notify_hook_present
    check "Codex notify hook installed"   codex_notify_hook_present
  fi
  if [[ -e "$GRAVE_ROOT/config/workspaces.json" ]]; then
    # Route through the root helper: the workspace doctor stats root-owned 0700
    # service-env files and grave-<slug>-owned homes, which the invoking owner
    # can't traverse — run unprivileged it raises PermissionError and fails on a
    # healthy box. Same path as every other `grave users` operation.
    check "workspace registry and ownership" sudo -n "$0" __users doctor
  fi
  if [[ "${MULTI_USER:-0}" == 1 ]]; then
    check "identity gateway loopback health" curl -sf -o /dev/null "http://127.0.0.1:${GATEWAY_PORT:-4710}/healthz"
    check "gateway capability is private" bash -c "[[ \$(stat -c %a '$GRAVE_ROOT/config/secrets/gateway-token') == 600 ]]"
    check "gateway is the Serve origin" bash -c "tailscale serve status | grep -q '127.0.0.1:${GATEWAY_PORT:-4710}'"
    check "Tailscale LocalAPI hidden from workspaces" bash -c "[[ \$(stat -c %a /run/tailscale/tailscaled.sock) == 660 ]]"
  fi
  echo
  if (( FAILURES > 0 && ! no_page )); then
    # Page the human about a failing contract (muteable via NOTIFY_EVENTS,
    # silent no-op when unconfigured). Subshell: cmd_notify exits, doctor must
    # still print its own verdict below.
    ( cmd_notify --event doctor --priority high --link "/grave/?tab=system" "doctor: $FAILURES check(s) failed" "on $(hostname) — run: grave doctor" ) || true
  fi
  if (( FAILURES == 0 )); then say "${GRN}${BLD}All checks passed.${RST}"; else say "${RED}${BLD}$FAILURES check(s) failed.${RST}"; exit 1; fi
}

# ---------------------------------------------------------------- backup ----
backup_tar() { # backup_tar <label> <out.tar.gz> <tar args…> — create + verify
  # Listing the archive back proves it decompresses end to end — a truncated
  # write (disk full mid-run) otherwise looks identical to a good backup until
  # restore day. Counts into cmd_backup's `failures` (bash dynamic scope).
  local label="$1" out="$2"; shift 2
  if tar -czf "$out" "$@" 2>/dev/null && tar -tzf "$out" >/dev/null 2>&1; then
    ok "$label"
  else
    bad "$label failed"; failures=$((failures+1))
  fi
}

cmd_backup() {
  local include_secrets=0
  [[ "${1:-}" == "--include-secrets" ]] && include_secrets=1
  need_root_helper
  local ts dest failures=0; ts=$(date +%Y%m%d-%H%M%S); dest="$BACKUP_DIR/$ts"
  mkdir -p "$dest"/{repos,volumes,configs}
  say "Backing up to $dest"

  # Every artifact is verified as it lands and any miss fails the whole run
  # (#112): the nightly unit must land in failed state — and page via
  # OnFailure= — rather than let retention quietly age out the last good copy.
  # The .last-verified marker is written only on a clean run, so doctor's
  # freshness check means "a backup that verifies", not "the timer fired".
  local repo name
  for repo in "$GRAVE_ROOT"/repos/*/; do
    [[ -d "$repo/.git" ]] || continue
    name=$(basename "$repo")
    # A repo with no commits has nothing to lose and `bundle create --all`
    # errors on it — skip it rather than page every night about a fresh clone.
    git -C "$repo" rev-parse --quiet --verify HEAD >/dev/null 2>&1 \
      || { say "  ${YLW}– repo $name has no commits — skipped${RST}"; continue; }
    if git -C "$repo" bundle create "$dest/repos/$name.bundle" --all 2>/dev/null \
       && git bundle verify "$dest/repos/$name.bundle" >/dev/null 2>&1; then
      ok "repo $name (git bundle, verified)"
    else
      bad "repo $name bundle failed"; failures=$((failures+1))
    fi
  done

  local excludes=(--exclude='config/secrets' --exclude='workspaces/*/config/secrets' --exclude='workspaces/*/.config/gh' --exclude='workspaces/*/.codex/auth.json' --exclude='workspaces/*/.claude/.credentials.json' --exclude='workspaces/*/.claude.json')
  (( include_secrets )) && excludes=()
  backup_tar "platform config" "$dest/configs/grave-platform.tar.gz" \
    "${excludes[@]}" -C "$GRAVE_ROOT" config docker docs scripts
  if [[ -d "$GRAVE_ROOT/workspaces" ]]; then
    backup_tar "workspace homes, state, and dirty worktrees" "$dest/configs/workspaces.tar.gz" \
      "${excludes[@]}" -C "$GRAVE_ROOT" workspaces
  fi
  printf '{"version":1,"secrets_included":%s,"created":"%s"}\n' "$([[ $include_secrets == 1 ]] && echo true || echo false)" "$(date -u +%FT%TZ)" >"$dest/manifest.json"
  local d
  for d in "${AGENT_CONFIG_DIRS[@]}"; do
    [[ -e "$HOME/$d" ]] && backup_tar "agent config $d" "$dest/configs/${d#.}.tar.gz" \
      --exclude="$d/auth.json" --exclude="$d/.credentials.json" -C "$HOME" "$d"
  done
  [[ -d "$GRAVE_ROOT/agents/t3code" ]] && backup_tar "t3code state" "$dest/configs/t3code-state.tar.gz" \
    -C "$GRAVE_ROOT/agents" t3code

  if dkctl is-active --quiet docker; then
    local vol
    for vol in $(dk volume ls -q | grep -vE '^[0-9a-f]{64}$'); do
      if dk run --rm -v "$vol":/data:ro -v "$dest/volumes":/backup alpine \
           tar -czf "/backup/$vol.tar.gz" -C /data . \
         && tar -tzf "$dest/volumes/$vol.tar.gz" >/dev/null 2>&1; then
        ok "volume $vol (verified)"
      else
        bad "volume $vol failed"; failures=$((failures+1))
      fi
    done
  else
    say "  ${YLW}docker stopped — volumes skipped this run${RST}"
  fi

  # retention — only timestamped backups (YYYYMMDD-HHMMSS). $BACKUP_DIR also holds
  # migration-* and removed-workspaces/, which sort AFTER the digits and would
  # otherwise occupy the "keep last N" slots, pruning real backups early (and
  # risk rm-ing non-backup dirs). Filter to the backup name shape.
  local old
  while IFS= read -r old; do
    rm -rf "$BACKUP_DIR/${old:?}"; say "  pruned old backup $old"
  done < <(ls -1 "$BACKUP_DIR" 2>/dev/null | grep -E '^[0-9]{8}-[0-9]{6}$' | sort | head -n -"$BACKUP_KEEP")
  if (( failures > 0 )); then
    log "backup: $ts FAILED ($failures artifact(s))"
    bad "backup incomplete: $failures artifact(s) failed — kept at $dest; freshness marker not updated"
    exit 1
  fi
  date -u +%FT%TZ >"$BACKUP_DIR/.last-verified"
  log "backup: $ts complete"
  ok "backup complete: $dest"
}

cmd_restore() {
  local ts="${1:-}"
  if [[ -z "$ts" ]]; then
    hdr "Available backups"
    ls -1 "$BACKUP_DIR" 2>/dev/null || say "(none)"
    say ""
    say "usage: grave restore <backup> [volume <name> | repo <name> | workspaces]"
    say "Full procedures: $GRAVE_ROOT/docs/RECOVERY.md"
    return
  fi
  local dest="$BACKUP_DIR/$ts"
  [[ -d "$dest" ]] || { bad "no such backup: $ts"; exit 1; }
  case "${2:-}" in
    volume)
      local vol="${3:?volume name}"
      # $vol flows into `docker run -v $vol:/data` and a container `sh -c`, so an
      # unvalidated value could bind a host path (vol=/etc) or inject shell.
      [[ "$vol" =~ ^[A-Za-z0-9_.-]+$ ]] || { bad "volume name must be letters, digits, '.', '-' or '_'"; exit 1; }
      dk volume create "$vol" >/dev/null
      dk run --rm -v "$vol":/data -v "$dest/volumes":/backup:ro alpine \
        sh -c "cd /data && tar -xzf /backup/$vol.tar.gz"
      ok "volume $vol restored from $ts" ;;
    repo)
      local name="${3:?repo name}"
      git clone "$dest/repos/$name.bundle" "$GRAVE_ROOT/repos/$name-restored"
      ok "repo restored to $GRAVE_ROOT/repos/$name-restored" ;;
    workspaces)
      [[ -f "$dest/configs/workspaces.tar.gz" ]] || { bad "backup has no workspace archive"; exit 1; }
      tar -C "$GRAVE_ROOT" -xzf "$dest/configs/grave-platform.tar.gz" config/workspaces.json 2>/dev/null || true
      tar -C "$GRAVE_ROOT" -xzf "$dest/configs/workspaces.tar.gz"
      ok "workspace data restored; run raise.sh then grave doctor" ;;
    *)
      say "Backup contents of $ts:"; find "$dest" -type f | sed "s|$dest/|  |"
      say ""; say "Restore a piece: grave restore $ts volume <name> | repo <name>"
      say "Full procedures: $GRAVE_ROOT/docs/RECOVERY.md" ;;
  esac
}

# ------------------------------------------------------------ multi-user ----
cmd_multiuser() {
  local sub="${1:-status}"; shift || true
  case "$sub" in
    status)
      say "multi-user: $([[ "${MULTI_USER:-0}" == 1 ]] && echo enabled || echo disabled)"
      [[ -r "$GRAVE_ROOT/config/workspaces.json" ]] && "$(dirname "$0")/grave-workspaces" list || true
      ;;
    enable)
      [[ $EUID == 0 ]] || { bad "multi-user migration requires root helper"; exit 1; }
      [[ "${MULTI_USER:-0}" != 1 ]] || { ok "multi-user mode already enabled"; return; }
      local identity="${1:?stable Tailscale numeric user ID}" login="${2:?owner Tailscale login}" slug="${3:?owner workspace slug}"; shift 3
      tailscale status --json | jq -e --arg id "$identity" --arg login "$login" '.User[$id].LoginName == $login' >/dev/null \
        || { bad "owner stable ID/login is not confirmed by local Tailscale state"; exit 1; }
      local profile=generic
      [[ "${1:-}" == --profile ]] && { profile="${2:?profile}"; shift 2; }
      local owner="${SUDO_USER:-$(stat -c %U "$GRAVE_ROOT")}" owner_home helper migration conf_backup
      owner_home=$(getent passwd "$owner" | cut -d: -f6); helper="$(dirname "$0")/grave-workspaces"
      migration="$GRAVE_ROOT/backups/migration-$(date +%Y%m%d-%H%M%S)"; mkdir -p "$migration"
      conf_backup="$migration/grave.conf"; cp "$CONF" "$conf_backup"
      tailscale serve get-config "$migration/serve.json" >/dev/null 2>&1 || true
      HOME="$owner_home" cmd_backup
      GRAVE_ROOT="$GRAVE_ROOT" GRAVE_WORKSPACE_START=0 "$helper" add "$identity" "$login" "$slug" --role admin
      local target="$GRAVE_ROOT/workspaces/$slug"
      [[ -d "$GRAVE_ROOT/agents/t3code" ]] && cp -a --reflink=auto "$GRAVE_ROOT/agents/t3code/." "$target/state/t3/"
      [[ -d "$GRAVE_ROOT/repos" ]] && cp -a --reflink=auto "$GRAVE_ROOT/repos/." "$target/repos/"
      for d in .config/gh .codex .claude; do [[ -e "$owner_home/$d" ]] && { mkdir -p "$target/$(dirname "$d")"; cp -a "$owner_home/$d" "$target/$d"; }; done
      [[ -f "$owner_home/.gitconfig" ]] && cp -a "$owner_home/.gitconfig" "$target/.gitconfig"
      [[ -f "$GRAVE_ROOT/config/secrets/linear.env" ]] && cp -a "$GRAVE_ROOT/config/secrets/linear.env" "$target/config/secrets/linear.env"
      [[ -f "$GRAVE_ROOT/config/gravedecay-settings.json" ]] && cp -a "$GRAVE_ROOT/config/gravedecay-settings.json" "$target/config/gravedecay-settings.json"
      local provider_lines
      provider_lines=$(grep -E '^(OPENAI_API_KEY|ANTHROPIC_API_KEY)=' "$GRAVE_ROOT/config/secrets/t3.env" 2>/dev/null || true)
      [[ -n "$provider_lines" && ! -e "$GRAVE_ROOT/config/secrets/provider.env" ]] && { printf '%s\n' "$provider_lines" >"$GRAVE_ROOT/config/secrets/provider.env"; chmod 600 "$GRAVE_ROOT/config/secrets/provider.env"; }
      chown -R "grave-$slug:grave-$slug" "$target"
      chown root:root "$GRAVE_ROOT/config/workspace-services/$slug.env"; chmod 600 "$GRAVE_ROOT/config/workspace-services/$slug.env"
      local repo name url
      for repo in "$target"/repos/*; do
        [[ -d "$repo/.git" ]] || continue; name=$(basename "$repo"); url=$(git -C "$repo" remote get-url origin 2>/dev/null || true)
        [[ -n "$url" ]] && GRAVE_ROOT="$GRAVE_ROOT" "$helper" adopt "$slug" "$name" "$url"
      done
      if grep -q '^MULTI_USER=' "$CONF"; then sed -i 's/^MULTI_USER=.*/MULTI_USER=1/' "$CONF"; else printf '\nMULTI_USER=1\nGATEWAY_PORT=4710\n' >>"$CONF"; fi
      if sudo -u "$owner" -H "$REPO_DIR/raise.sh" --profile "$profile"; then
        systemctl disable --now t3code gravedecay-term >/dev/null 2>&1 || true
        printf '{"state":"enabled","owner":"%s","backup":"%s"}\n' "$slug" "$migration" >"$GRAVE_ROOT/config/multiuser-migration.json"
        audit_msg="multi-user enabled owner=$slug"; log "$audit_msg"; ok "$audit_msg"
      else
        cp "$conf_backup" "$CONF"
        sudo -u "$owner" -H "$REPO_DIR/raise.sh" --profile "$profile" || true
        printf '{"state":"rolled-back","workspace_retained":"%s"}\n' "$slug" >"$GRAVE_ROOT/config/multiuser-migration.json"
        bad "migration failed; single-user config restored and workspace retained"; exit 1
      fi
      ;;
    *) say "usage: grave multiuser [status|enable <tailscale-id> <login> <slug> --profile <profile>]"; exit 1 ;;
  esac
}

# ------------------------------------------------------------------ help ----
cmd_help() {
  cat <<'EOF'
grave — gravedecay appliance control 🪦

  grave status               overview: services, containers, agents, system
  grave doctor               verify every platform invariant
  grave users [status|list|add|inspect|disable|remove]
  grave projects [list|grant|revoke|git-config]
  grave integrations [status|github-login|github-logout|linear-set|linear-logout]
  grave provider [set|grant|revoke|status]
  grave multiuser [status|enable]

  grave gaming               🎮 free resources: stop services, FREEZE agent
                             sessions in place (🧊 torpor — RAM kept, zero CPU)
  grave gaming --kill        ☠️ same but destroy agent sessions (max free RAM)
  grave gaming --for 2h      ⏱️ torpor now, automatically restore after 2h
  grave developer            💻 thaw sessions + restore full development mode
  grave start | stop         same as developer / gaming (without the banner)
  grave restart              stop + start developer services

  grave agents               list agent tmux sessions
  grave agents new <n> [dir]    create persistent agent session
  grave agents attach <n>       attach (detach: Ctrl-b d)
  grave agents kill <n>         kill session
  grave agents history          past sessions — logs survive death; view 📜
                                and resume ▶ from the dashboard too
  grave agents resume <n>       recreate a dead session in its old dir

  grave docker [ps|up <stack>|down <stack>|logs <c>|stacks|disk]
  grave logs [t3|dash|ssh|tailscale|system|grave|agent <n>|<container/unit>]

  grave preview <port>       expose a running dev server (e.g. :3000) to the
                             tailnet at https://<box>.ts.net:<port> — root path,
                             so HMR/websockets just work. Server stays loopback.
  grave preview              auto-pick the one dev server listening in the range
  grave preview list         show active previews
  grave preview off <port>   stop a preview

  grave t3 [status|update]   show versions or install npm's stable T3 release
  grave releases            list selectable stable gravedecay releases
  grave update               snapshot (if snapper), update pkgs/npm/images
  grave upgrade              update gravedecay itself: pull latest release
                             (--tag vX.Y.Z pins one; --edge follows main)
  grave bootmode [dev|game]  what a reboot boots into: developer services
                             up (default) or gaming (ALWAYS_ON only)
  grave gamewatch [on|off]   persistent automatic gaming/developer switching;
                             'status' shows the watcher and last signal
  grave keepalive [on|off]   "always alive": warm tailnet relay paths so a
                             remote/relay device's websocket doesn't idle-drop
  grave notify <t> [body]    page your devices: ntfy topic and/or Web Push to
                             the installed PWA (enroll in ⚙️ settings). Agents,
                             failing units, and doctor use the same channels —
                             see docs/NOTIFICATIONS.md
  grave digest [--print]     morning summary (agents, spend, doctor, backup);
                             a timer pages it at ~08:00 — --print composes
                             without paging
  grave backup               bundle repos, configs, docker volumes — every
                             artifact verified; a timer runs one nightly and
                             doctor enforces freshness (docs/RECOVERY.md)
  grave restore [backup]     list / restore backups

Docs: $GRAVE_ROOT/docs   Config: /etc/gravedecay/grave.conf
EOF
}

# ------------------------------------------------------------------ main ----
case "${1:-help}" in
  __auto-thaw) shift || true; cmd_auto_thaw_root "$@" ;;
  status)     cmd_status ;;
  gaming)     shift || true; cmd_gaming "$@" ;;
  developer)  cmd_developer ;;
  start)      start_dev ;;
  stop)       shift || true; stop_dev "$@" ;;
  restart)    stop_dev; thaw_agents; start_dev ;;
  agents)     shift; cmd_agents "$@" ;;
  docker)     shift; cmd_docker "$@" ;;
  preview)    shift || true; cmd_preview "$@" ;;
  t3|t3code)  shift || true; cmd_t3 "$@" ;;
  update)     cmd_update ;;
  releases)   shift || true; cmd_releases "$@" ;;
  upgrade)    shift || true; cmd_upgrade "$@" ;;
  bootmode)   shift || true; cmd_bootmode "$@" ;;
  gamewatch)  shift || true; cmd_gamewatch "$@" ;;
  keepalive)  shift || true; cmd_keepalive "$@" ;;
  logs)       shift; cmd_logs "$@" ;;
  notify)     shift || true; cmd_notify "$@" ;;
  digest)     shift || true; cmd_digest "$@" ;;
  doctor)     shift || true; cmd_doctor "$@" ;;
  users)      shift || true; exec sudo -n "$0" __users "$@" ;;
  projects)
    shift || true; sub="${1:-list}"; shift || true
    case "$sub" in
      list) exec sudo -n "$0" __users projects "$@" ;;
      grant|revoke|git-config) exec sudo -n "$0" __users "$sub" "$@" ;;
      *) say "usage: grave projects [list <workspace>|grant <workspace> <name> <url>|revoke <workspace> <name>|git-config <workspace> --name N --email E]"; exit 1 ;;
    esac ;;
  integrations)
    shift || true; sub="${1:-status}"; shift || true
    case "$sub" in
      status) exec sudo -n "$0" __users integration-status "$@" ;;
      github-login|github-logout|linear-set|linear-logout) exec sudo -n "$0" __users "$sub" "$@" ;;
      *) say "usage: grave integrations [status <workspace>|github-login <workspace>|github-logout <workspace> --user U|linear-set <workspace>|linear-logout <workspace>]"; exit 1 ;;
    esac ;;
  provider)
    shift || true; sub="${1:-status}"; shift || true
    case "$sub" in
      set) exec sudo -n "$0" __users provider-set "$@" ;;
      grant|revoke) exec sudo -n "$0" __users provider-policy "$sub" "$@" ;;
      status) exec sudo -n "$0" __users provider-status "$@" ;;
      *) say "usage: grave provider [set|grant <workspace>|revoke <workspace>|status]"; exit 1 ;;
    esac ;;
  multiuser)  shift || true; exec sudo -n "$0" __multiuser "$@" ;;
  __multiuser) shift || true; cmd_multiuser "$@" ;;
  __users)    shift || true; [[ $EUID == 0 ]] || { bad "internal users helper requires root"; exit 1; }; exec "$(dirname "$0")/grave-workspaces" "$@" ;;
  backup)     shift || true; cmd_backup "$@" ;;
  restore)    shift || true; cmd_restore "$@" ;;
  help|--help|-h) cmd_help ;;
  *) say "unknown command: $1"; cmd_help; exit 1 ;;
esac
